_show_info() {
    echo ""
    echo "тХФтХРтХЧ тХФтХРтХЧ тХФтХРтХЧ тХФтХжтХЧ"
    echo "тХС   тХС   тХЪтХРтХЧ тХСтХСтХС"
    echo "тХЪтХРтХЭ тХЪтХРтХЭ тХЪтХРтХЭ тХй тХй"
    echo ""
    echo "ccsm - Claude Code Session Manager"
    echo ""
    echo "Quick setup (run once):"
    echo ""
    echo "  mkdir -p ~/.claude/hooks"
    echo "  cp /usr/share/ccsm/hooks/session_end.sh ~/.claude/hooks/ccsm_session_end.sh"
    echo "  [ ! -f ~/.claude/ccsm.conf ] && cp /usr/share/ccsm/ccsm.conf.example ~/.claude/ccsm.conf"
    echo ""
    echo "If ~/.claude/settings.json does not exist yet:"
    echo '  echo '"'"'{"hooks":{"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"bash ~/.claude/hooks/ccsm_session_end.sh","timeout":5}]}]}}'"'"' > ~/.claude/settings.json'
    echo ""
    echo "Start with: ccsm"
    echo ""
}

post_install() {
    _show_info
}

post_upgrade() {
    echo ""
    echo "ccsm upgraded. Updating hook:"
    echo "  cp /usr/share/ccsm/hooks/session_end.sh ~/.claude/hooks/ccsm_session_end.sh"
    _show_info
}

post_remove() {
    echo ""
    echo "ccsm removed. You may want to clean up:"
    echo "  rm -f ~/.claude/hooks/ccsm_session_end.sh"
    echo "  rm -f ~/.claude/ccsm.conf"
    echo "  # Session data: ~/.claude/session_log.tsv"
    echo "  # Remove hook from ~/.claude/settings.json"
    echo ""
}
