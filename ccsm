#!/bin/bash
# ccsm - Claude Code Session Manager
# https://github.com/mattlab76/ccsm
#
# Features:
#   - Start new or resume old sessions
#   - Auto-cd to session working directory
#   - Save sessions with subject and tags
#   - dialog-based TUI interface
#   - Auto-cleanup of old sessions
#   - Search, Statistics, Token tracking
#   - i18n (English/German)
#
# Usage:
#   ccsm                  Interactive menu
#   ccsm --search <text>  Search sessions
#   ccsm --stats          Show statistics
#   ccsm --cleanup        Manual cleanup
#   ccsm --help           Show help

CCSM_VERSION="1.3.0"

# Paths
SESSION_LOG="$HOME/.claude/session_log.tsv"
CONFIG_FILE="$HOME/.claude/ccsm.conf"
TMPDIR="/tmp/ccsm"
DIALOG_TMP="/tmp/ccsm-dialog.$$"

# Defaults
CLEANUP_DAYS=30
MAX_SESSIONS=0
CCSM_LANG="${CCSM_LANG:-}"

# Load config
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

# Language detection
if [[ -z "${CCSM_LANG:-}" ]]; then
    case "${LC_ALL:-${LANG:-}}" in
        de*) CCSM_LANG="de" ;;
        *)   CCSM_LANG="en" ;;
    esac
fi

