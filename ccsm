# Internal: search and select from results
_search_and_resume() {
    local query="$1"
    shift

    local SEARCH_SIDS=()
    local search_table_lines=()
    local idx=0

    search_table_lines+=("$(table_top)")
    search_table_lines+=("$(table_header_row)")
    search_table_lines+=("$(table_mid)")

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        if echo "$betreff $cwd $tags" | grep -qi "$query"; then
            idx=$((idx + 1))
            SEARCH_SIDS+=("$sid")

            local short_betreff="${betreff:0:$((_W_SUBJ - 2))}"
            [ ${#betreff} -gt $((_W_SUBJ - 2)) ] && short_betreff="${short_betreff}.."
            local short_cwd="${cwd/#$HOME/\~}"
            local short_cwd_d="${short_cwd:0:$((_W_DIR - 2))}"
            [ ${#short_cwd} -gt $((_W_DIR - 2)) ] && short_cwd_d="..${short_cwd: -$((_W_DIR - 4))}"

            local tot_in="0" tot_out="0" last_in="0" last_out="0"
            if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
                local total_part="${tokens_col%%|*}"
                local last_part="${tokens_col#*|}"
                [ "$last_part" = "$tokens_col" ] && last_part="$total_part"
                tot_in=$(echo "$total_part" | cut -d/ -f1)
                tot_out=$(echo "$total_part" | cut -d/ -f2)
                last_in=$(echo "$last_part" | cut -d/ -f1)
                last_out=$(echo "$last_part" | cut -d/ -f2)
            fi

            search_table_lines+=("$(table_data_row "$idx" "$datum" "$short_betreff" "$short_cwd_d" \
                "$(format_tokens "$tot_in")" "$(format_tokens "$tot_out")" \
                "$(format_tokens "$last_in")" "$(format_tokens "$last_out")")")
        fi
    done < <(tac "$SESSION_LOG")

    if [ ${#SEARCH_SIDS[@]} -eq 0 ]; then
        gum style --foreground="$C_WARN" "$(t search_no_results)"
        sleep 1
        return 1
    fi

    search_table_lines+=("$(table_bottom)")

    clear

    local cols
    cols=$(tput cols 2>/dev/null || echo 80)
    local binner=$((cols < 60 ? 56 : cols - 8))
    local dline=""
    for ((i=0; i<binner; i++)); do dline+="вХР"; done

    local box_lines=()
    box_lines+=("  ${A_TEAL}${A_BOLD}$(t search_title): '${query}'${A_RST}        ${A_DIM}${#SEARCH_SIDS[@]} result(s)${A_RST}")
    box_lines+=("")
    for line in "${search_table_lines[@]}"; do
        box_lines+=("  $line")
    done
    box_lines+=("")
    box_lines+=("$dline")
    box_lines+=("  ${A_GREEN}[1-${#SEARCH_SIDS[@]}]${A_RST} $(t msg_resuming)")
    box_lines+=("  ${A_GREEN}[q]${A_RST}     $(t menu_quit)")

    render_box "" "${box_lines[@]}"
    echo ""
    echo -n "  > "; read -r sel

    case "$sel" in
        q|Q|"") return 1 ;;
        [0-9]*)
            local sidx=$((sel - 1))
            if [ "$sidx" -ge 0 ] && [ "$sidx" -lt "${#SEARCH_SIDS[@]}" ]; then
                local sid="${SEARCH_SIDS[$sidx]}"
                local line
                line=$(grep "^${sid}	" "$SESSION_LOG")
                SELECTED_SID=$(echo "$line" | cut -f1)
                SELECTED_CWD=$(echo "$line" | cut -f2)
                SELECTED_BETREFF=$(echo "$line" | cut -f3)
                return 0
            fi
            return 1
            ;;
        *) return 1 ;;
    esac
}

###############################################################################
# Resume session
###############################################################################
resume_session() {
    local sid="$1" cwd="$2" betreff="$3"
    shift 3

    clear
    gum style --foreground="$C_ACCENT" --bold \
        "$(t msg_switching): $cwd" \
        "$(t msg_resuming): $betreff"
    echo ""

    cd "$cwd" || {
        gum style --foreground="$C_WARN" "$(t err_no_dir): $cwd"
        sleep 2
        return 1
    }
    claude --resume "$sid" "$@"
    save_session
}

###############################################################################
# Delete session
###############################################################################
delete_session() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        sleep 1
        return
    fi

    clear

    build_table 0
    local DELETE_SIDS=("${TABLE_SIDS[@]}")
    local session_count=${#DELETE_SIDS[@]}

    # Doppelte Trennlinie
    local cols
    cols=$(tput cols 2>/dev/null || echo 80)
    local binner=$((cols < 60 ? 56 : cols - 8))
    local dline=""
    for ((i=0; i<binner; i++)); do dline+="вХР"; done

    local box_lines=()
    box_lines+=("  ${A_VIOLET}вХФвХРвХЧ вХФвХРвХЧ вХФвХРвХЧ вХФвХ¶вХЧ${A_RST}   ${A_BOLD}$(t delete_title)${A_RST}        ${A_DIM}${session_count} session(s)${A_RST}")
    box_lines+=("  ${A_VIOLET}вХС   вХС   вХЪвХРвХЧ вХСвХСвХС${A_RST}")
    box_lines+=("  ${A_VIOLET}вХЪвХРвХЭ вХЪвХРвХЭ вХЪвХРвХЭ вХ© вХ©${A_RST}")
    box_lines+=("")
    box_lines+=("$dline")
    box_lines+=("  ${A_TEAL}${A_BOLD}$(t delete_title)${A_RST}")
    box_lines+=("")
    for line in "${TABLE_LINES[@]}"; do
        box_lines+=("  $line")
    done
    box_lines+=("")
    box_lines+=("$dline")
    box_lines+=("  ${A_TEAL}${A_BOLD}$(t menu_action)${A_RST}")
    box_lines+=("")
    box_lines+=("  ${A_GREEN}[1-${session_count}]${A_RST} Enter number(s) to delete (comma-separated: 1,3,5)")
    box_lines+=("  ${A_GREEN}[q]${A_RST}     Back")

    render_box "" "${box_lines[@]}"
    echo ""
    echo -n "  > "; read -r del_input

    case "$del_input" in
        q|Q|"") return ;;
    esac

    # Parse comma-separated numbers
    local delete_sids=()
    IFS=',' read -ra nums <<< "$del_input"
    for num in "${nums[@]}"; do
        num=$(echo "$num" | tr -d ' ')
        local idx=$((num - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "$session_count" ]; then
            delete_sids+=("${DELETE_SIDS[$idx]}")
        fi
    done

    [ ${#delete_sids[@]} -eq 0 ] && return

    # Confirm
    echo ""
    echo -n "  $(t delete_confirm) (${#delete_sids[@]} selected) [y/n]: "; read -r confirm
    [[ "${confirm,,}" != "y" ]] && [[ "${confirm,,}" != "j" ]] && return

    # Delete from log
    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        local sid_match=false
        for del_sid in "${delete_sids[@]}"; do
            [ "$s" = "$del_sid" ] && sid_match=true && break
        done
        if $sid_match; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        echo -e "  ${A_GREEN}вЬУ ${msg}${A_RST}"
        sleep 1
    fi
}

