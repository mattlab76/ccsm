#!/bin/bash
# ccsm - Claude Code Session Manager
# https://github.com/mattlab76/ccsm
#
# Features:
#   - Start new or resume old sessions
#   - Auto-cd to session working directory
#   - Save sessions with subject and tags
#   - Quick resume (a-e) from menu
#   - fzf fuzzy search integration
#   - Auto-cleanup of old sessions
#   - Search (--search)
#   - Statistics
#   - i18n (English/German)
#
# Usage:
#   ccsm                  Interactive menu
#   ccsm --search <text>  Search sessions
#   ccsm --stats          Show statistics
#   ccsm --cleanup        Manual cleanup
#   ccsm --help           Show help

CCSM_VERSION="1.2.0"

# Paths
SESSION_LOG="$HOME/.claude/session_log.tsv"
CONFIG_FILE="$HOME/.claude/ccsm.conf"
TMPDIR="/tmp/ccsm"

# Defaults
CLEANUP_DAYS=30
MAX_SESSIONS=0
CCSM_LANG="${CCSM_LANG:-}"

# Load config (before language detection so CCSM_LANG can be set there)
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

# Language detection: Config > Env > Locale > English
if [[ -z "${CCSM_LANG:-}" ]]; then
    case "${LC_ALL:-${LANG:-}}" in
        de*) CCSM_LANG="de" ;;
        *)   CCSM_LANG="en" ;;
    esac
fi

