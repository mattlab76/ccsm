###############################################################################
# Main
###############################################################################
main() {
    case "${1:-}" in
        --search) shift; search_sessions "$*"; return ;;
        --stats) show_stats; return ;;
        --cleanup) check_cleanup; return ;;
        --version|-v) echo "ccsm v${CCSM_VERSION}"; return ;;
        --help|-h) show_help; return ;;
    esac

    check_cleanup

    while true; do
        show_main_menu

        case "$MENU_CHOICE" in
            *"$(t menu_new)"*)
                clear
                echo "$(t msg_starting)"
                echo ""
                claude "$@"
                save_session
                ;;
            *"$(t menu_resume)"*)
                if quick_resume; then
                    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF" "$@"
                fi
                ;;
            *"$(t menu_delete)"*)
                delete_session
                ;;
            *"$(t menu_stats)"*)
                show_stats
                ;;
            *"$(t menu_quit)"*)
                clear
                exit 0
                ;;
        esac
    done
}

[[ "${CCSM_TESTING:-}" == "true" ]] || main "$@"
