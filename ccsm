###############################################################################
# Helper: days since date
###############################################################################
days_since() {
    local date_str="$1"
    local now today_sec date_sec
    now=$(date '+%Y-%m-%d')
    today_sec=$(date -d "$now" '+%s' 2>/dev/null) || today_sec=$(date '+%s')
    date_sec=$(date -d "$date_str" '+%s' 2>/dev/null) || return 1
    echo $(( (today_sec - date_sec) / 86400 ))
}

###############################################################################
# Helper: build session menu items for dialog
###############################################################################
build_session_menu() {
    local max_items="${1:-0}"
    local count=0
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local short_cwd="${cwd/#$HOME/\~}"
        local short_betreff="${betreff:0:40}"
        [ ${#betreff} -gt 40 ] && short_betreff="${short_betreff}.."
        local tag_str=""
        [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
        local tok_str=""
        [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ] && tok_str=" ${tokens_col}"
        echo "$sid"
        echo "${datum}  ${short_betreff}${tag_str}${tok_str}  ${short_cwd}"
        count=$((count + 1))
        [ "$max_items" -gt 0 ] && [ "$count" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")
}

###############################################################################
# Cleanup old sessions
###############################################################################
check_cleanup() {
    [ ! -s "$SESSION_LOG" ] && return
    [ "$CLEANUP_DAYS" -eq 0 ] 2>/dev/null && return

    local checklist_args=()
    local has_old=false

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local age
        age=$(days_since "$datum" 2>/dev/null) || continue
        if [ "$age" -ge "$CLEANUP_DAYS" ]; then
            has_old=true
            local short_betreff="${betreff:0:40}"
            checklist_args+=("$sid" "${datum} (${age}d) ${short_betreff}" "off")
        fi
    done < "$SESSION_LOG"

    $has_old || return

    local cleanup_text
    printf -v cleanup_text "$(t cleanup_text)" "$CLEANUP_DAYS"

    dialog --backtitle "$(t title)" \
        --title "$(t cleanup_title)" \
        --checklist "$cleanup_text" 20 70 10 \
        "${checklist_args[@]}" 2>"$DIALOG_TMP"

    local status=$?
    [ "$status" -ne 0 ] && return

    local to_delete
    to_delete=$(cat "$DIALOG_TMP")
    [ -z "$to_delete" ] && return

    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        if echo "$to_delete" | grep -q "$s"; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        dialog --backtitle "$(t title)" --msgbox "$msg" 7 40
    fi
}

###############################################################################
# Main menu
###############################################################################
show_menu() {
    local menu_args=()

    # Recent sessions (a-e)
    if [ -s "$SESSION_LOG" ]; then
        local i=0
        local keys=(a b c d e)
        while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
            local key="${keys[$i]}"
            local short_cwd="${cwd/#$HOME/\~}"
            local short_betreff="${betreff:0:35}"
            [ ${#betreff} -gt 35 ] && short_betreff="${short_betreff}.."
            local tag_str=""
            [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
            local tok_str=""
            [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ] && tok_str=" ${tokens_col}"

            # Store for quick access
            eval "QUICK_SID_${key}='$sid'"
            eval "QUICK_CWD_${key}='$cwd'"
            eval "QUICK_BETREFF_${key}='$betreff'"

            menu_args+=("$key" "${datum} ${short_betreff}${tag_str}${tok_str} ${short_cwd}")
            i=$((i + 1))
        done < <(tac "$SESSION_LOG" | head -5)

        menu_args+=("" "─────────────────────────────────────────")
    fi

    menu_args+=("1" "$(t menu_new)")
    menu_args+=("2" "$(t menu_resume)")
    menu_args+=("3" "$(t menu_delete)")
    menu_args+=("4" "$(t menu_stats)")
    menu_args+=("q" "$(t menu_quit)")

    local count=0
    [ -s "$SESSION_LOG" ] && count=$(wc -l < "$SESSION_LOG")

    dialog --backtitle "$(t title) v${CCSM_VERSION}" \
        --title "ccsm  [$count sessions]" \
        --cancel-label "$(t menu_quit)" \
        --menu "" 22 78 15 \
        "${menu_args[@]}" 2>"$DIALOG_TMP"

    local status=$?
    if [ "$status" -ne 0 ]; then
        MENU_CHOICE="q"
    else
        MENU_CHOICE=$(cat "$DIALOG_TMP")
    fi
}

###############################################################################
# Resume session
###############################################################################
resume_session() {
    local sid="$1" cwd="$2" betreff="$3"
    shift 3

    clear
    echo "$(t msg_switching): $cwd"
    echo "$(t msg_resuming): $betreff"
    echo ""
    cd "$cwd" || {
        dialog --backtitle "$(t title)" --msgbox "$(t err_no_dir): $cwd" 7 50
        return 1
    }
    claude --resume "$sid" "$@"
    save_session
}

###############################################################################
# Select session (dialog menu)
###############################################################################
select_session() {
    if [ ! -s "$SESSION_LOG" ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t sessions_none)" 7 40
        return 1
    fi

    local menu_args=()
    while IFS= read -r line; do
        menu_args+=("$line")
    done < <(build_session_menu)

    dialog --backtitle "$(t title)" \
        --title "$(t menu_resume)" \
        --menu "" 20 78 12 \
        "${menu_args[@]}" 2>"$DIALOG_TMP"

    local status=$?
    [ "$status" -ne 0 ] && return 1

    local sid
    sid=$(cat "$DIALOG_TMP")
    [ -z "$sid" ] && return 1

    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    return 0
}

###############################################################################
# Delete session
###############################################################################
delete_session() {
    if [ ! -s "$SESSION_LOG" ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t sessions_none)" 7 40
        return
    fi

    local menu_args=()
    while IFS= read -r line; do
        menu_args+=("$line")
    done < <(build_session_menu)

    dialog --backtitle "$(t title)" \
        --title "$(t delete_title)" \
        --menu "" 20 78 12 \
        "${menu_args[@]}" 2>"$DIALOG_TMP"

    local status=$?
    [ "$status" -ne 0 ] && return

    local sid
    sid=$(cat "$DIALOG_TMP")
    [ -z "$sid" ] && return

    local betreff
    betreff=$(grep "^${sid}	" "$SESSION_LOG" | cut -f3)

    local confirm_msg
    printf -v confirm_msg "$(t delete_confirm)" "$betreff"
    dialog --backtitle "$(t title)" \
        --title "$(t delete_title)" \
        --yesno "$confirm_msg" 10 50

    if [ $? -eq 0 ]; then
        local tmplog="${SESSION_LOG}.tmp"
        grep -v "^${sid}	" "$SESSION_LOG" > "$tmplog" || true
        mv "$tmplog" "$SESSION_LOG"
        dialog --backtitle "$(t title)" --msgbox "$(t delete_done)" 7 30
    fi
}

###############################################################################
# Search sessions
###############################################################################
search_sessions() {
    local query="$1"

    if [ ! -s "$SESSION_LOG" ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t search_no_sessions)" 7 40
        return 1
    fi

    # Get search term if not provided
    if [ -z "$query" ]; then
        dialog --backtitle "$(t title)" \
            --title "$(t search_title)" \
            --inputbox "$(t search_prompt)" 8 50 2>"$DIALOG_TMP"
        [ $? -ne 0 ] && return 1
        query=$(cat "$DIALOG_TMP")
        [ -z "$query" ] && return 1
    fi

    # Search and build results
    local menu_args=()
    local found=0
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        if echo "$betreff $cwd $tags" | grep -qi "$query"; then
            local short_cwd="${cwd/#$HOME/\~}"
            local short_betreff="${betreff:0:40}"
            local tag_str=""
            [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
            menu_args+=("$sid" "${datum}  ${short_betreff}${tag_str}  ${short_cwd}")
            found=$((found + 1))
        fi
    done < <(tac "$SESSION_LOG")

    if [ "$found" -eq 0 ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t search_no_results)" 7 40
        return 1
    fi

    dialog --backtitle "$(t title)" \
        --title "$(t search_results): '$query' ($found)" \
        --menu "" 20 78 12 \
        "${menu_args[@]}" 2>"$DIALOG_TMP"

    local status=$?
    [ "$status" -ne 0 ] && return 1

    local sid
    sid=$(cat "$DIALOG_TMP")
    [ -z "$sid" ] && return 1

    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF"
}

###############################################################################
# Statistics
###############################################################################
show_stats() {
    if [ ! -s "$SESSION_LOG" ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t stats_none)" 7 40
        return
    fi

    local total oldest newest
    total=$(wc -l < "$SESSION_LOG")
    oldest=$(head -1 "$SESSION_LOG" | cut -f4)
    newest=$(tail -1 "$SESSION_LOG" | cut -f4)

    # Top directories
    local top_dirs
    top_dirs=$(cut -f2 "$SESSION_LOG" | sed "s|$HOME|~|g" | sort | uniq -c | sort -rn | head -5 | awk '{printf "  %dx  %s\n", $1, $2}')

    # Token totals
    local total_in=0 total_out=0
    while IFS=$'\t' read -r _ _ _ _ _ tk; do
        if [ -n "$tk" ] && [ "$tk" != "0/0" ]; then
            local t_in t_out
            t_in=$(echo "$tk" | cut -d/ -f1)
            t_out=$(echo "$tk" | cut -d/ -f2)
            total_in=$((total_in + t_in))
            total_out=$((total_out + t_out))
        fi
    done < "$SESSION_LOG"

    # Top tags
    local top_tags
    top_tags=$(cut -f5 "$SESSION_LOG" 2>/dev/null | grep -v '^$' | grep -v '^-$' | tr ' ' '\n' | sort | uniq -c | sort -rn | head -5 | awk '{printf "  %s (%dx)\n", $2, $1}')

    local stats_text="Version:       ${CCSM_VERSION}
Total:         ${total} Sessions
Oldest:        ${oldest}
Newest:        ${newest}
Cleanup:       ${CLEANUP_DAYS} days

Top directories:
${top_dirs}

Tokens:
  Input:  ${total_in}
  Output: ${total_out}"

    [ -n "$top_tags" ] && stats_text="${stats_text}

Top tags:
${top_tags}"

    dialog --backtitle "$(t title)" \
        --title "$(t stats_title)" \
        --msgbox "$stats_text" 22 60
}

###############################################################################
# Subject suggestions from transcript
###############################################################################
generate_suggestions() {
    local transcript="$1" cwd="$2"
    python3 - "$transcript" "$cwd" "$CCSM_LANG" <<'PYEOF'
import json, sys, os

transcript_path = sys.argv[1]
cwd = sys.argv[2]
lang = sys.argv[3] if len(sys.argv) > 3 else "en"
suggestions = []
user_messages = []

try:
    with open(transcript_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get('type') == 'user' and 'message' in obj:
                    msg = obj['message']
                    if isinstance(msg, dict) and msg.get('role') == 'user':
                        for c in msg.get('content', []):
                            if isinstance(c, dict) and c.get('type') == 'text':
                                text = c['text'].strip().replace('\n', ' ').replace('\t', ' ')
                                if len(text) > 5:
                                    user_messages.append(text)
            except (json.JSONDecodeError, KeyError):
                pass
except Exception:
    pass

if user_messages:
    first = user_messages[0][:80]
    if len(user_messages[0]) > 80: first += ".."
    suggestions.append(first)

dir_name = os.path.basename(cwd)
prefix = "Work in" if lang == "en" else "Arbeit in"
if dir_name and dir_name != os.path.basename(os.path.expanduser('~')):
    suggestions.append(f"{prefix}: {dir_name}")

if user_messages and dir_name:
    first_short = user_messages[0][:40]
    if len(user_messages[0]) > 40: first_short += ".."
    suggestions.append(f"{dir_name}: {first_short}")

seen = set()
for s in suggestions:
    if s not in seen:
        seen.add(s)
        print(s)
PYEOF
}

###############################################################################
# Save session (guided dialog flow)
###############################################################################
save_session() {
    local tmpfile=""
    tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
    [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ] && [ -f "/tmp/claude-session-end.json" ] && tmpfile="/tmp/claude-session-end.json"

    if [ -z "$tmpfile" ]; then
        local waited=0
        while [ $waited -lt 10 ]; do
            sleep 0.5
            waited=$((waited + 1))
            tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
            [ -n "$tmpfile" ] && break
        done
    fi

    if [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ]; then
        dialog --backtitle "$(t title)" --msgbox "$(t save_no_data)" 7 50
        return
    fi

    local sid cwd betreff transcript tokens
    sid=$(jq -r '.session_id' "$tmpfile" 2>/dev/null)
    cwd=$(jq -r '.cwd' "$tmpfile" 2>/dev/null)
    betreff=$(jq -r '.betreff' "$tmpfile" 2>/dev/null)
    transcript=$(jq -r '.transcript // empty' "$tmpfile" 2>/dev/null)
    tokens=$(jq -r '.tokens // "0/0"' "$tmpfile" 2>/dev/null)
    [ -z "$sid" ] && return

    local datum
    datum=$(date '+%Y-%m-%d')
    local existing_line
    existing_line=$(grep "^${sid}	" "$SESSION_LOG" 2>/dev/null)

    if [ -n "$existing_line" ]; then
        # Existing session — keep or change subject
        local existing_betreff existing_tags existing_tokens
        existing_betreff=$(echo "$existing_line" | cut -f3)
        existing_tags=$(echo "$existing_line" | cut -f5)
        existing_tokens=$(echo "$existing_line" | cut -f6)

        local keep_msg
        printf -v keep_msg "$(t save_keep_or_new)" "$existing_betreff"

        dialog --backtitle "$(t title)" \
            --title "$(t save_title)" \
            --yes-label "$(t save_keep)" \
            --no-label "$(t save_change)" \
            --yesno "$keep_msg" 10 60

        local new_betreff="$existing_betreff"
        if [ $? -ne 0 ]; then
            dialog --backtitle "$(t title)" \
                --title "$(t save_title)" \
                --inputbox "$(t save_enter)" 8 60 "$existing_betreff" 2>"$DIALOG_TMP"
            [ $? -eq 0 ] && new_betreff=$(cat "$DIALOG_TMP")
        fi

        # Accumulate tokens
        local new_tokens="$tokens"
        if [ -n "$existing_tokens" ] && [ "$existing_tokens" != "0/0" ] && [ -n "$tokens" ] && [ "$tokens" != "0/0" ]; then
            local old_in old_out cur_in cur_out
            old_in=$(echo "$existing_tokens" | cut -d/ -f1)
            old_out=$(echo "$existing_tokens" | cut -d/ -f2)
            cur_in=$(echo "$tokens" | cut -d/ -f1)
            cur_out=$(echo "$tokens" | cut -d/ -f2)
            new_tokens="$(( old_in + cur_in ))/$(( old_out + cur_out ))"
        fi

        local tmplog="${SESSION_LOG}.tmp"
        while IFS=$'\t' read -r s c b d t_col tk; do
            if [ "$s" = "$sid" ]; then
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$new_betreff" "$datum" "$t_col" "$new_tokens"
            else
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
            fi
        done < "$SESSION_LOG" > "$tmplog"
        mv "$tmplog" "$SESSION_LOG"
        dialog --backtitle "$(t title)" --msgbox "$(t save_updated)" 7 30
    else
        # New session — guided save flow

        # Step 1: Save?
        dialog --backtitle "$(t title)" \
            --title "$(t save_title) [${tokens} tok]" \
            --yesno "$(t save_want)\n\nDir: $cwd\nTokens: $tokens" 10 60

        if [ $? -ne 0 ]; then
            rm -f "$tmpfile"
            return
        fi

        # Step 2: Auto-subject
        local auto_betreff=""
        if [ -n "$transcript" ] && [ -f "$transcript" ]; then
            auto_betreff=$(generate_suggestions "$transcript" "$cwd" | head -1)
        fi
        [ -z "$auto_betreff" ] && auto_betreff="Session $(basename "$cwd") $datum"

        dialog --backtitle "$(t title)" \
            --title "$(t save_title)" \
            --yesno "$(t save_accept)\n\n$auto_betreff" 10 60

        local chosen_betreff=""
        if [ $? -eq 0 ]; then
            chosen_betreff="$auto_betreff"
        else
            # Step 3: Custom subject (with retry)
            while true; do
                dialog --backtitle "$(t title)" \
                    --title "$(t save_title)" \
                    --inputbox "$(t save_enter)" 8 60 "$auto_betreff" 2>"$DIALOG_TMP"

                if [ $? -ne 0 ]; then
                    rm -f "$tmpfile"
                    return
                fi

                chosen_betreff=$(cat "$DIALOG_TMP")
                if [ -n "$chosen_betreff" ]; then
                    break
                fi

                dialog --backtitle "$(t title)" \
                    --yesno "$(t save_no_empty)" 7 50
                [ $? -ne 0 ] && { rm -f "$tmpfile"; return; }
            done
        fi

        # Step 4: Tags
        local chosen_tags="-"
        dialog --backtitle "$(t title)" \
            --title "Tags" \
            --inputbox "$(t save_tags)" 8 60 2>"$DIALOG_TMP"

        if [ $? -eq 0 ]; then
            local tag_input
            tag_input=$(cat "$DIALOG_TMP")
            [ -n "$tag_input" ] && chosen_tags=$(echo "$tag_input" | tr '\t' ' ')
        fi

        # Save
        chosen_betreff=$(echo "$chosen_betreff" | tr '\t' ' ')
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$sid" "$cwd" "$chosen_betreff" "$datum" "$chosen_tags" "$tokens" >> "$SESSION_LOG"
        dialog --backtitle "$(t title)" --msgbox "$(t save_saved): $chosen_betreff" 7 60
    fi

    rm -f "$tmpfile"
}

###############################################################################
# Help
###############################################################################
show_help() {
    if [[ "$CCSM_LANG" == "de" ]]; then
        cat <<'EOF'
ccsm — Claude Code Session Manager

Nutzung:
  ccsm                  Interaktives Menü (dialog)
  ccsm --search <text>  Sessions durchsuchen
  ccsm --stats          Statistiken anzeigen
  ccsm --cleanup        Cleanup manuell starten
  ccsm --version        Version anzeigen
  ccsm --help           Diese Hilfe

Konfiguration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30   Tage bis eine Session als alt gilt
  MAX_SESSIONS=0    Max. Sessions (0=unbegrenzt)
  CCSM_LANG=de      Sprache (en, de)
EOF
    else
        cat <<'EOF'
ccsm — Claude Code Session Manager

Usage:
  ccsm                  Interactive menu (dialog)
  ccsm --search <text>  Search sessions
  ccsm --stats          Show statistics
  ccsm --cleanup        Manual cleanup
  ccsm --version        Show version
  ccsm --help           Show this help

Configuration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30   Days until a session is considered old
  MAX_SESSIONS=0    Max sessions (0=unlimited)
  CCSM_LANG=en      Language (en, de)
EOF
    fi
}

###############################################################################
# Main
###############################################################################
main() {
    case "${1:-}" in
        --search) shift; search_sessions "$*"; return ;;
        --stats) show_stats; return ;;
        --cleanup) check_cleanup; return ;;
        --version|-v) echo "ccsm v${CCSM_VERSION}"; return ;;
        --help|-h) show_help; return ;;
    esac

    check_cleanup

    while true; do
        show_menu

        case "$MENU_CHOICE" in
            a|b|c|d|e)
                local key="$MENU_CHOICE"
                local sid_var="QUICK_SID_${key}"
                local cwd_var="QUICK_CWD_${key}"
                local betreff_var="QUICK_BETREFF_${key}"
                if [ -n "${!sid_var}" ]; then
                    resume_session "${!sid_var}" "${!cwd_var}" "${!betreff_var}" "$@"
                fi
                ;;
            1)
                clear
                echo "$(t msg_starting)"
                echo ""
                claude "$@"
                save_session
                ;;
            2) if select_session; then resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF" "$@"; fi ;;
            3) delete_session ;;
            4) show_stats ;;
            q|Q|"") clear; exit 0 ;;
        esac
    done
}

[[ "${CCSM_TESTING:-}" == "true" ]] || main "$@"
