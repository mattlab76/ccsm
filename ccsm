# gum renders its TUI on stderr. Some terminal setups (p10k, zsh plugins)
# suppress stderr display. We redirect stderr to /dev/tty so the TUI is
# always visible, while stdout (the result) stays capturable by $().
gum() { command gum "$@" 2>/dev/tty; }

###############################################################################
# Token formatting: 1353202 -> "1.4M", 47567 -> "47.6k", 102 -> "102"
###############################################################################
format_tokens() {
    local n="$1"
    if [[ -z "$n" ]] || [[ "$n" == "0" ]]; then
        echo "0"
        return
    fi
    # LC_ALL=C ensures dot as decimal separator
    if [ "$n" -ge 1000000 ] 2>/dev/null; then
        LC_ALL=C printf "%.1fM" "$(echo "scale=1; $n/1000000" | LC_ALL=C bc)"
    elif [ "$n" -ge 1000 ] 2>/dev/null; then
        LC_ALL=C printf "%.1fk" "$(echo "scale=1; $n/1000" | LC_ALL=C bc)"
    else
        echo "$n"
    fi
}

###############################################################################
# Helper: days since date
###############################################################################
days_since() {
    local date_str="$1"
    local now today_sec date_sec
    now=$(date '+%Y-%m-%d')
    today_sec=$(date -d "$now" '+%s' 2>/dev/null) || today_sec=$(date '+%s')
    date_sec=$(date -d "$date_str" '+%s' 2>/dev/null) || return 1
    echo $(( (today_sec - date_sec) / 86400 ))
}

###############################################################################
# Session table with box-drawing borders
# Column widths: # (3), Date (12), Subject (20), Dir (16), TotIn (7), TotOut (7), LastIn (7), LastOut (7)
###############################################################################
TABLE_SIDS=()

# Calculate column widths dynamically based on terminal width
calc_columns() {
    local cols
    cols=$(tput cols 2>/dev/null || echo 100)
    # Available width inside outer box: cols - 12 (outer box padding + borders + inner padding)
    local avail=$((cols - 12))
    # Fixed columns
    _W_NUM=3
    _W_DATE=12
    # Token columns: minimum 9, scale up with terminal
    _W_TI=$(( avail * 8 / 100 )); [ "$_W_TI" -lt 9 ] && _W_TI=9
    _W_TO=$_W_TI; _W_LI=$_W_TI; _W_LO=$_W_TI
    # Remaining space split: 55% subject, 45% directory
    local remaining=$((avail - _W_NUM - _W_DATE - _W_TI * 4 - 9)) # 9 = separators
    _W_SUBJ=$((remaining * 55 / 100)); [ "$_W_SUBJ" -lt 18 ] && _W_SUBJ=18
    _W_DIR=$((remaining - _W_SUBJ)); [ "$_W_DIR" -lt 14 ] && _W_DIR=14
}
calc_columns

_hline() {
    local char="${1:-вФА}"
    local w=$2
    local s=""
    for ((i=0; i<w; i++)); do s+="$char"; done
    echo -n "$s"
}

