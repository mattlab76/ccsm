        return
    fi

    local total
    total=$(wc -l < "$SESSION_LOG")
    local oldest newest
    oldest=$(head -1 "$SESSION_LOG" | cut -f4)
    newest=$(tail -1 "$SESSION_LOG" | cut -f4)

    echo ""
    echo -e "${BOLD}ŌĢÉŌĢÉŌĢÉ $(t stats_title) ŌĢÉŌĢÉŌĢÉ${RESET}"
    echo ""
    echo -e "  ${BOLD}$(t stats_version):${RESET}         ${CCSM_VERSION}"
    echo -e "  ${BOLD}$(t stats_total):${RESET}          ${total} Sessions"
    echo -e "  ${BOLD}$(t stats_oldest):${RESET}         ${oldest}"
    echo -e "  ${BOLD}$(t stats_newest):${RESET}         ${newest}"
    printf "  ${BOLD}$(t stats_cleanup):${RESET}    $(t stats_days)\n" "$CLEANUP_DAYS"
    echo -e "  ${BOLD}fzf:${RESET}             $($HAS_FZF && echo "${GREEN}$(t stats_fzf_available)${RESET}" || echo "${YELLOW}$(t stats_fzf_missing)${RESET}")"

    echo ""
    echo -e "  ${BOLD}$(t stats_top_dirs):${RESET}"
    cut -f2 "$SESSION_LOG" | sort | uniq -c | sort -rn | head -5 | while read -r count dir; do
        local short_dir="${dir/#$HOME/~}"
        echo -e "    ${GREEN}${count}x${RESET}  ${short_dir}"
    done

    # Token totals
    local total_in=0 total_out=0
    while IFS=$'\t' read -r _ _ _ _ _ tk; do
        if [ -n "$tk" ] && [ "$tk" != "0/0" ]; then
            local t_in t_out
            t_in=$(echo "$tk" | cut -d/ -f1)
            t_out=$(echo "$tk" | cut -d/ -f2)
            total_in=$((total_in + t_in))
            total_out=$((total_out + t_out))
        fi
    done < "$SESSION_LOG"

    if [ $((total_in + total_out)) -gt 0 ]; then
        echo ""
        echo -e "  ${BOLD}$(t stats_tokens):${RESET}"
        printf "    $(t stats_tokens_in):  %'d\n" "$total_in"
        printf "    $(t stats_tokens_out): %'d\n" "$total_out"
    fi

    local tags_col
    tags_col=$(cut -f5 "$SESSION_LOG" 2>/dev/null | grep -v '^$' | grep -v '^-$' | tr ' ' '\n' | sort | uniq -c | sort -rn | head -5)
    if [ -n "$tags_col" ]; then
        echo ""
        echo -e "  ${BOLD}$(t stats_top_tags):${RESET}"
        echo "$tags_col" | while read -r count tag; do
            echo -e "    ${MAGENTA}${tag}${RESET} (${count}x)"
        done
    fi
    echo ""
}

###############################################################################
# Subject suggestions from transcript
###############################################################################
generate_suggestions() {
    local transcript="$1" cwd="$2"
    python3 - "$transcript" "$cwd" "$CCSM_LANG" <<'PYEOF'
import json, sys, os

transcript_path = sys.argv[1]
cwd = sys.argv[2]
lang = sys.argv[3] if len(sys.argv) > 3 else "en"

suggestions = []
user_messages = []

try:
    with open(transcript_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get('type') == 'user' and 'message' in obj:
                    msg = obj['message']
                    if isinstance(msg, dict) and msg.get('role') == 'user':
                        for c in msg.get('content', []):
                            if isinstance(c, dict) and c.get('type') == 'text':
                                text = c['text'].strip().replace('\n', ' ').replace('\t', ' ')
                                if len(text) > 5:
                                    user_messages.append(text)
            except (json.JSONDecodeError, KeyError):
                pass
except Exception:
    pass

if user_messages:
    first = user_messages[0][:80]
    if len(user_messages[0]) > 80: first += ".."
    suggestions.append(first)

dir_name = os.path.basename(cwd)
prefix = "Work in" if lang == "en" else "Arbeit in"
if dir_name and dir_name != os.path.basename(os.path.expanduser('~')):
    suggestions.append(f"{prefix}: {dir_name}")

if len(user_messages) > 1:
    second = user_messages[1][:80]
    if len(user_messages[1]) > 80: second += ".."
    suggestions.append(second)

if user_messages and dir_name:
    first_short = user_messages[0][:40]
    if len(user_messages[0]) > 40: first_short += ".."
    suggestions.append(f"{dir_name}: {first_short}")

if len(user_messages) > 2:
    last = user_messages[-1][:80]
    if len(user_messages[-1]) > 80: last += ".."
    if last != suggestions[0]: suggestions.append(last)

seen = set()
for s in suggestions:
    if s not in seen:
        seen.add(s)
        print(s)
PYEOF
}

###############################################################################
# Choose subject interactively
###############################################################################
choose_betreff() {
    local transcript="$1" cwd="$2"
    CHOSEN_BETREFF="__SKIP__"

    local yes_char
    yes_char=$(t confirm_yes)
    local yn="(${yes_char^^}/${yes_char,,}=n)"

    # Step 1: Do you want to save?
    echo ""
    echo -n "$(t save_want_save) [$(t confirm_yes)/n]: "; read -r save_yn
    if ! is_yes "$save_yn" && [ -n "$save_yn" ]; then
        CHOSEN_BETREFF="__SKIP__"
        return
    fi

    # Generate auto-subject
    local auto_betreff=""
    if [ -n "$transcript" ] && [ -f "$transcript" ]; then
        auto_betreff=$(generate_suggestions "$transcript" "$cwd" | head -1)
    fi
    if [ -z "$auto_betreff" ]; then
        local dir_name
        dir_name=$(basename "$cwd")
        auto_betreff="Session $dir_name $(date '+%Y-%m-%d')"
    fi

    # Step 2: Accept auto-subject?
    echo -e "  $(t save_auto_label): ${CYAN}${auto_betreff}${RESET}"
    echo -n "$(t save_accept_subject) [$(t confirm_yes)/n]: "; read -r accept_yn
    if is_yes "$accept_yn" || [ -z "$accept_yn" ]; then
        CHOSEN_BETREFF=$(echo "$auto_betreff" | tr '\t' ' ')
        return
    fi

    # Step 3: Enter custom subject (with retry loop)
    while true; do
        echo -n "$(t save_enter_subject)"; read -r custom
        if [ -n "$custom" ]; then
            CHOSEN_BETREFF=$(echo "$custom" | tr '\t' ' ')
            return
        fi

        # Empty input
        echo -e "${YELLOW}$(t save_no_empty)${RESET}"
        echo -n "$(t save_retry_or_cancel)"; read -r retry
        local retry_lower="${retry,,}"
        # EN: t=try again, c=cancel / DE: n=nochmal, a=abbrechen
        if [[ "$retry_lower" == "c" ]] || [[ "$retry_lower" == "a" ]]; then
            CHOSEN_BETREFF="__SKIP__"
            return
        fi
    done
}

