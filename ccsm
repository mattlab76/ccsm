###############################################################################
# Main
###############################################################################
main() {
    case "${1:-}" in
        --search) shift; search_sessions "$*"; return ;;
        --stats) show_stats; return ;;
        --cleanup) check_cleanup; return ;;
        --version|-v) echo "ccsm v${CCSM_VERSION}"; return ;;
        --help|-h) show_help; return ;;
    esac

    check_cleanup
    show_menu

    case "$MENU_CHOICE" in
        a|b|c|d|e)
            local key="$MENU_CHOICE"
            if [ -n "${QUICK_SID[$key]}" ]; then
                resume_session "${QUICK_SID[$key]}" "${QUICK_CWD[$key]}" "${QUICK_BETREFF[$key]}" "$@"
            else
                printf "${YELLOW}$(t err_no_session)${RESET}\n" "$key"
                exit 1
            fi
            ;;
        1)
            echo -e "\n${GREEN}$(t msg_starting)${RESET}\n"
            claude "$@"
            save_session
            ;;
        2) if select_session; then resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF" "$@"; fi ;;
        3) delete_session ;;
        4) show_stats ;;
        q|Q|"") echo "$(t msg_goodbye)"; exit 0 ;;
        *) echo -e "${YELLOW}$(t err_invalid)${RESET}"; exit 1 ;;
    esac
}

[[ "${CCSM_TESTING:-}" == "true" ]] || main "$@"
