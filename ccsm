        return 1
    fi

    if $HAS_FZF && [ -z "$query" ]; then
        local selection
        selection=$(tac "$SESSION_LOG" | while IFS=$'\t' read -r sid cwd betreff datum tags; do
            local short_cwd="${cwd/#$HOME/~}"
            local tag_str=""
            [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
            echo "${datum}  ${betreff}${tag_str}  ${short_cwd}  ::${sid}::"
        done | fzf --ansi --prompt="$(t fzf_search_prompt)" --header="$(t fzf_select_header)" --reverse --height=40%)

        [ -z "$selection" ] && return 1
        local sid
        sid=$(echo "$selection" | grep -oP '::.*?::' | tr -d ':')
        [ -z "$sid" ] && return 1
        local line
        line=$(grep "^${sid}	" "$SESSION_LOG")
        SELECTED_SID=$(echo "$line" | cut -f1)
        SELECTED_CWD=$(echo "$line" | cut -f2)
        SELECTED_BETREFF=$(echo "$line" | cut -f3)
        resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF"
    else
        echo ""
        echo -e "${BOLD}$(t search_results): ${CYAN}${query}${RESET}"
        echo -e "${BOLD}ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ${RESET}"
        local found=0
        while IFS=$'\t' read -r sid cwd betreff datum tags; do
            if echo "$betreff $cwd $tags" | grep -qi "$query"; then
                local short_cwd="${cwd/#$HOME/~}"
                local tag_str=""
                [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [${tags}]"
                echo -e "  ${YELLOW}${datum}${RESET}  ${BOLD}${betreff}${RESET}${MAGENTA}${tag_str}${RESET}"
                echo -e "  ${CYAN}${short_cwd}${RESET}  ${DIM}${sid}${RESET}"
                echo ""
                found=$((found + 1))
            fi
        done < <(tac "$SESSION_LOG")

        if [ "$found" -eq 0 ]; then
            echo -e "  ${YELLOW}$(t search_no_results)${RESET}"
        else
            printf "  ${DIM}$(t search_hits)${RESET}\n" "$found"
        fi
    fi
}

