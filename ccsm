###############################################################################
# Helper: days since date
###############################################################################
days_since() {
    local date_str="$1"
    local now today_sec date_sec
    now=$(date '+%Y-%m-%d')
    today_sec=$(date -d "$now" '+%s' 2>/dev/null) || today_sec=$(date '+%s')
    date_sec=$(date -d "$date_str" '+%s' 2>/dev/null) || return 1
    echo $(( (today_sec - date_sec) / 86400 ))
}

###############################################################################
# Show styled header
###############################################################################
show_header() {
    echo ""
    gum style \
        --foreground="$C_PRIMARY" \
        --border="rounded" \
        --border-foreground="$C_SECONDARY" \
        --padding="1 3" \
        --margin="0 2" \
        --bold \
        "╔═╗ ╔═╗ ╔═╗ ╔╦╗" \
        "║   ║   ╚═╗ ║║║" \
        "╚═╝ ╚═╝ ╚═╝ ╩ ╩" \
        "" \
        "$(t title) v${CCSM_VERSION}"

    local count=0
    [ -s "$SESSION_LOG" ] && count=$(wc -l < "$SESSION_LOG")
    gum style --foreground="$C_DIM" --margin="0 4" "$count session(s)"
}

###############################################################################
# Show session table
###############################################################################
show_session_table() {
    local max_items="${1:-0}"

    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        return 1
    fi

    # Build formatted table lines
    local header
    printf -v header "  %-12s %-35s %-22s %-12s %s" "Date" "Subject" "Directory" "Tags" "Tokens"
    local lines=()
    lines+=("$header")
    lines+=("  $(printf '─%.0s' {1..90})")

    local count=0
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local short_cwd="${cwd/#$HOME/\~}"
        local short_betreff="${betreff:0:33}"
        [ ${#betreff} -gt 33 ] && short_betreff="${short_betreff}.."
        local short_cwd_d="${short_cwd:0:20}"
        [ ${#short_cwd} -gt 20 ] && short_cwd_d="..${short_cwd: -18}"
        local tag_str="${tags:--}"
        [ "$tag_str" = "-" ] && tag_str=""
        local tok_str="${tokens_col:-}"
        [ "$tok_str" = "0/0" ] && tok_str=""

        local row
        printf -v row "  %-12s %-35s %-22s %-12s %s" "$datum" "$short_betreff" "$short_cwd_d" "$tag_str" "$tok_str"
        lines+=("$row")

        count=$((count + 1))
        [ "$max_items" -gt 0 ] && [ "$count" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")

    gum style --foreground="$C_DIM" "${lines[@]}"
}

###############################################################################
# Build session choices for gum choose
###############################################################################
build_choices() {
    local max_items="${1:-0}"
    local count=0
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local short_cwd="${cwd/#$HOME/\~}"
        local short_betreff="${betreff:0:35}"
        [ ${#betreff} -gt 35 ] && short_betreff="${short_betreff}.."
        local tag_str=""
        [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
        local tok_str=""
        [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ] && tok_str=" ${tokens_col}"
        echo "${datum}  ${short_betreff}${tag_str}${tok_str}  ${short_cwd}  ::${sid}::"
        count=$((count + 1))
        [ "$max_items" -gt 0 ] && [ "$count" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")
}

###############################################################################
# Extract session ID from choice string
###############################################################################
extract_sid() {
    echo "$1" | grep -oP '::.*?::' | tr -d ':'
}

###############################################################################
# Cleanup old sessions
###############################################################################
check_cleanup() {
    [ ! -s "$SESSION_LOG" ] && return
    [ "$CLEANUP_DAYS" -eq 0 ] 2>/dev/null && return

    local old_items=()
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local age
        age=$(days_since "$datum" 2>/dev/null) || continue
        if [ "$age" -ge "$CLEANUP_DAYS" ]; then
            old_items+=("${datum} (${age}d)  ${betreff}  ::${sid}::")
        fi
    done < "$SESSION_LOG"

    [ ${#old_items[@]} -eq 0 ] && return

    local cleanup_title
    printf -v cleanup_title "$(t cleanup_title)" "$CLEANUP_DAYS"

    gum style --foreground="$C_WARN" --bold --margin="1 2" "$cleanup_title"

    local to_delete
    to_delete=$(printf '%s\n' "${old_items[@]}" | \
        gum choose --no-limit \
            --header="Space=select  Enter=confirm  (select sessions to DELETE)" \
            --cursor.foreground="$C_WARN" \
            --selected.foreground="$C_WARN") || return

    [ -z "$to_delete" ] && return

    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        if echo "$to_delete" | grep -q "::${s}::"; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        gum style --foreground="$C_ACCENT" "$msg"
        sleep 1
    fi
}

###############################################################################
# Main menu
###############################################################################
show_main_menu() {
    clear
    show_header
    echo ""

    # Show recent sessions table
    if [ -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_DIM" --margin="0 4" "Recent sessions:"
        show_session_table 5
        echo ""
    fi

    # Menu choices
    local choices=()
    choices+=("$(t menu_new)")
    choices+=("$(t menu_resume)")
    choices+=("$(t menu_delete)")
    choices+=("$(t menu_stats)")
    choices+=("$(t menu_quit)")

    MENU_CHOICE=$(printf '%s\n' "${choices[@]}" | \
        gum choose \
            --header="" \
            --cursor.foreground="$C_PRIMARY" \
            --selected.foreground="$C_SECONDARY" \
            --height=7) || MENU_CHOICE="$(t menu_quit)"
}

###############################################################################
# Quick resume (select from recent sessions)
###############################################################################
quick_resume() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        sleep 1
        return 1
    fi

    local choice
    choice=$(build_choices | \
        gum choose \
            --header="$(t menu_resume)" \
            --cursor.foreground="$C_PRIMARY") || return 1

    local sid
    sid=$(extract_sid "$choice")
    [ -z "$sid" ] && return 1

    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    return 0
}

###############################################################################
# Resume session
###############################################################################
resume_session() {
    local sid="$1" cwd="$2" betreff="$3"
    shift 3

    clear
    gum style --foreground="$C_ACCENT" --bold \
        "$(t msg_switching): $cwd" \
        "$(t msg_resuming): $betreff"
    echo ""

    cd "$cwd" || {
        gum style --foreground="$C_WARN" "$(t err_no_dir): $cwd"
        sleep 2
        return 1
    }
    claude --resume "$sid" "$@"
    save_session
}

###############################################################################
# Delete session
###############################################################################
delete_session() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        sleep 1
        return
    fi

    local choice
    choice=$(build_choices | \
        gum choose \
            --header="$(t delete_title)" \
            --cursor.foreground="$C_WARN") || return

    local sid
    sid=$(extract_sid "$choice")
    [ -z "$sid" ] && return

    local betreff
    betreff=$(grep "^${sid}	" "$SESSION_LOG" | cut -f3)

    gum confirm --prompt.foreground="$C_WARN" "$(t delete_confirm)
$betreff" || return

    local tmplog="${SESSION_LOG}.tmp"
    grep -v "^${sid}	" "$SESSION_LOG" > "$tmplog" || true
    mv "$tmplog" "$SESSION_LOG"
    gum style --foreground="$C_ACCENT" "✓ $(t delete_done)"
    sleep 1
}

###############################################################################
# Search sessions
###############################################################################
search_sessions() {
    local query="$1"

    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t search_no_sessions)"
        sleep 1
        return 1
    fi

    if [ -z "$query" ]; then
        query=$(gum input \
            --placeholder="$(t search_prompt)..." \
            --prompt.foreground="$C_PRIMARY" \
            --cursor.foreground="$C_SECONDARY") || return 1
        [ -z "$query" ] && return 1
    fi

    local results=()
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        if echo "$betreff $cwd $tags" | grep -qi "$query"; then
            local short_cwd="${cwd/#$HOME/\~}"
            local short_betreff="${betreff:0:35}"
            local tag_str=""
            [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
            results+=("${datum}  ${short_betreff}${tag_str}  ${short_cwd}  ::${sid}::")
        fi
    done < <(tac "$SESSION_LOG")

    if [ ${#results[@]} -eq 0 ]; then
        gum style --foreground="$C_WARN" "$(t search_no_results)"
        sleep 1
        return 1
    fi

    local choice
    choice=$(printf '%s\n' "${results[@]}" | \
        gum choose \
            --header="$(t search_title): '$query' (${#results[@]})" \
            --cursor.foreground="$C_PRIMARY") || return 1

    local sid
    sid=$(extract_sid "$choice")
    [ -z "$sid" ] && return 1

    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF"
}

###############################################################################
# Statistics
###############################################################################
show_stats() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t stats_none)"
        sleep 1
        return
    fi

    clear
    local total oldest newest
    total=$(wc -l < "$SESSION_LOG")
    oldest=$(head -1 "$SESSION_LOG" | cut -f4)
    newest=$(tail -1 "$SESSION_LOG" | cut -f4)

    # Token totals
    local total_in=0 total_out=0
    while IFS=$'\t' read -r _ _ _ _ _ tk; do
        if [ -n "$tk" ] && [ "$tk" != "0/0" ]; then
            local t_in t_out
            t_in=$(echo "$tk" | cut -d/ -f1)
            t_out=$(echo "$tk" | cut -d/ -f2)
            total_in=$((total_in + t_in))
            total_out=$((total_out + t_out))
        fi
    done < "$SESSION_LOG"

    gum style \
        --foreground="$C_PRIMARY" \
        --border="rounded" \
        --border-foreground="$C_SECONDARY" \
        --padding="1 3" \
        --margin="1 2" \
        --bold \
        "$(t stats_title)"

    gum style --margin="0 4" \
        "Version:     ${CCSM_VERSION}" \
        "Sessions:    ${total}" \
        "Oldest:      ${oldest}" \
        "Newest:      ${newest}" \
        "Cleanup:     ${CLEANUP_DAYS} days" \
        "" \
        "Tokens in:   ${total_in}" \
        "Tokens out:  ${total_out}"

    # Top directories
    echo ""
    gum style --foreground="$C_DIM" --margin="0 4" "Top directories:"
    cut -f2 "$SESSION_LOG" | sed "s|$HOME|~|g" | sort | uniq -c | sort -rn | head -5 | \
        awk '{printf "  %dx  %s\n", $1, $2}'

    # Top tags
    local top_tags
    top_tags=$(cut -f5 "$SESSION_LOG" 2>/dev/null | grep -v '^$' | grep -v '^-$' | tr ' ' '\n' | sort | uniq -c | sort -rn | head -5)
    if [ -n "$top_tags" ]; then
        echo ""
        gum style --foreground="$C_DIM" --margin="0 4" "Top tags:"
        echo "$top_tags" | awk '{printf "  %s (%dx)\n", $2, $1}'
    fi

    # Full session table
    echo ""
    gum style --foreground="$C_DIM" --margin="0 4" "All sessions:"
    show_session_table

    echo ""
    read -rp ""
}

###############################################################################
# Subject suggestions from transcript
###############################################################################
generate_suggestions() {
    local transcript="$1" cwd="$2"
    python3 - "$transcript" "$cwd" "$CCSM_LANG" <<'PYEOF'
import json, sys, os

transcript_path = sys.argv[1]
cwd = sys.argv[2]
lang = sys.argv[3] if len(sys.argv) > 3 else "en"
suggestions = []
user_messages = []

try:
    with open(transcript_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get('type') == 'user' and 'message' in obj:
                    msg = obj['message']
                    if isinstance(msg, dict) and msg.get('role') == 'user':
                        for c in msg.get('content', []):
                            if isinstance(c, dict) and c.get('type') == 'text':
                                text = c['text'].strip().replace('\n', ' ').replace('\t', ' ')
                                if len(text) > 5:
                                    user_messages.append(text)
            except (json.JSONDecodeError, KeyError):
                pass
except Exception:
    pass

if user_messages:
    first = user_messages[0][:80]
    if len(user_messages[0]) > 80: first += ".."
    suggestions.append(first)

dir_name = os.path.basename(cwd)
prefix = "Work in" if lang == "en" else "Arbeit in"
if dir_name and dir_name != os.path.basename(os.path.expanduser('~')):
    suggestions.append(f"{prefix}: {dir_name}")

if user_messages and dir_name:
    first_short = user_messages[0][:40]
    if len(user_messages[0]) > 40: first_short += ".."
    suggestions.append(f"{dir_name}: {first_short}")

seen = set()
for s in suggestions:
    if s not in seen:
        seen.add(s)
        print(s)
PYEOF
}

###############################################################################
# Save session (guided gum flow)
###############################################################################
save_session() {
    local tmpfile=""
    tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
    [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ] && [ -f "/tmp/claude-session-end.json" ] && tmpfile="/tmp/claude-session-end.json"

    if [ -z "$tmpfile" ]; then
        local waited=0
        while [ $waited -lt 10 ]; do
            sleep 0.5
            waited=$((waited + 1))
            tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
            [ -n "$tmpfile" ] && break
        done
    fi

    if [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ]; then
        gum style --foreground="$C_WARN" "$(t save_no_data)"
        sleep 2
        return
    fi

    local sid cwd betreff transcript tokens
    sid=$(jq -r '.session_id' "$tmpfile" 2>/dev/null)
    cwd=$(jq -r '.cwd' "$tmpfile" 2>/dev/null)
    betreff=$(jq -r '.betreff' "$tmpfile" 2>/dev/null)
    transcript=$(jq -r '.transcript // empty' "$tmpfile" 2>/dev/null)
    tokens=$(jq -r '.tokens // "0/0"' "$tmpfile" 2>/dev/null)
    [ -z "$sid" ] && return

    local datum
    datum=$(date '+%Y-%m-%d')
    local existing_line
    existing_line=$(grep "^${sid}	" "$SESSION_LOG" 2>/dev/null)

    echo ""
    gum style \
        --foreground="$C_PRIMARY" \
        --border="rounded" \
        --border-foreground="$C_SECONDARY" \
        --padding="0 2" \
        "$(t save_title)" \
        "Dir: ${cwd}" \
        "Tokens: ${tokens} (in/out)"

    if [ -n "$existing_line" ]; then
        # Existing session
        local existing_betreff existing_tags existing_tokens
        existing_betreff=$(echo "$existing_line" | cut -f3)
        existing_tags=$(echo "$existing_line" | cut -f5)
        existing_tokens=$(echo "$existing_line" | cut -f6)

        local action
        action=$(printf '%s\n' "$(t save_keep): $existing_betreff" "$(t save_change)" | \
            gum choose --cursor.foreground="$C_PRIMARY") || { rm -f "$tmpfile"; return; }

        local new_betreff="$existing_betreff"
        if [[ "$action" == "$(t save_change)" ]]; then
            new_betreff=$(gum input \
                --value="$existing_betreff" \
                --prompt.foreground="$C_PRIMARY" \
                --cursor.foreground="$C_SECONDARY" \
                --placeholder="$(t save_enter)") || new_betreff="$existing_betreff"
        fi

        # Accumulate tokens
        local new_tokens="$tokens"
        if [ -n "$existing_tokens" ] && [ "$existing_tokens" != "0/0" ] && [ -n "$tokens" ] && [ "$tokens" != "0/0" ]; then
            local old_in old_out cur_in cur_out
            old_in=$(echo "$existing_tokens" | cut -d/ -f1)
            old_out=$(echo "$existing_tokens" | cut -d/ -f2)
            cur_in=$(echo "$tokens" | cut -d/ -f1)
            cur_out=$(echo "$tokens" | cut -d/ -f2)
            new_tokens="$(( old_in + cur_in ))/$(( old_out + cur_out ))"
        fi

        local tmplog="${SESSION_LOG}.tmp"
        while IFS=$'\t' read -r s c b d t_col tk; do
            if [ "$s" = "$sid" ]; then
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$new_betreff" "$datum" "$t_col" "$new_tokens"
            else
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
            fi
        done < "$SESSION_LOG" > "$tmplog"
        mv "$tmplog" "$SESSION_LOG"
        gum style --foreground="$C_ACCENT" "✓ $(t save_updated): $new_betreff"
    else
        # New session — guided flow

        # Step 1: Save?
        if ! gum confirm --prompt.foreground="$C_PRIMARY" "$(t save_want)"; then
            gum style --foreground="$C_DIM" "$(t save_not_saved)"
            rm -f "$tmpfile"
            sleep 1
            return
        fi

        # Step 2: Auto-subject
        local auto_betreff=""
        if [ -n "$transcript" ] && [ -f "$transcript" ]; then
            auto_betreff=$(generate_suggestions "$transcript" "$cwd" | head -1)
        fi
        [ -z "$auto_betreff" ] && auto_betreff="Session $(basename "$cwd") $datum"

        local chosen_betreff=""
        if gum confirm --prompt.foreground="$C_PRIMARY" "$(t save_accept)
$auto_betreff"; then
            chosen_betreff="$auto_betreff"
        else
            # Step 3: Custom subject
            while true; do
                chosen_betreff=$(gum input \
                    --value="$auto_betreff" \
                    --prompt.foreground="$C_PRIMARY" \
                    --cursor.foreground="$C_SECONDARY" \
                    --placeholder="$(t save_enter)") || { rm -f "$tmpfile"; return; }

                [ -n "$chosen_betreff" ] && break

                if ! gum confirm --prompt.foreground="$C_WARN" "$(t save_no_empty)"; then
                    rm -f "$tmpfile"
                    return
                fi
            done
        fi

        # Step 4: Tags
        local chosen_tags="-"
        local tag_input
        tag_input=$(gum input \
            --placeholder="$(t save_tags)" \
            --prompt.foreground="$C_SECONDARY" \
            --cursor.foreground="$C_PRIMARY") || true
        [ -n "$tag_input" ] && chosen_tags=$(echo "$tag_input" | tr '\t' ' ')

        # Save
        chosen_betreff=$(echo "$chosen_betreff" | tr '\t' ' ')
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$sid" "$cwd" "$chosen_betreff" "$datum" "$chosen_tags" "$tokens" >> "$SESSION_LOG"
        gum style --foreground="$C_ACCENT" "✓ $(t save_saved): $chosen_betreff"
    fi

    sleep 1
    rm -f "$tmpfile"
}

###############################################################################
# Help
###############################################################################
show_help() {
    if [[ "$CCSM_LANG" == "de" ]]; then
        cat <<EOF
ccsm v${CCSM_VERSION} — Claude Code Session Manager

Nutzung:
  ccsm                  Interaktives Menü
  ccsm --search <text>  Sessions durchsuchen
  ccsm --stats          Statistiken anzeigen
  ccsm --cleanup        Cleanup manuell starten
  ccsm --version        Version anzeigen
  ccsm --help           Diese Hilfe

Konfiguration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30   Tage bis Session als alt gilt
  MAX_SESSIONS=0    Max. Sessions (0=unbegrenzt)
  CCSM_LANG=de      Sprache (en, de)
EOF
    else
        cat <<EOF
ccsm v${CCSM_VERSION} — Claude Code Session Manager

Usage:
  ccsm                  Interactive menu
  ccsm --search <text>  Search sessions
  ccsm --stats          Show statistics
  ccsm --cleanup        Manual cleanup
  ccsm --version        Show version
  ccsm --help           Show this help

Configuration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30   Days until session is considered old
  MAX_SESSIONS=0    Max sessions (0=unlimited)
  CCSM_LANG=en      Language (en, de)
EOF
    fi
}

###############################################################################
# Main
###############################################################################
main() {
    case "${1:-}" in
        --search) shift; search_sessions "$*"; return ;;
        --stats) show_stats; return ;;
        --cleanup) check_cleanup; return ;;
        --version|-v) echo "ccsm v${CCSM_VERSION}"; return ;;
        --help|-h) show_help; return ;;
    esac

    check_cleanup

    while true; do
        show_main_menu

        case "$MENU_CHOICE" in
            *"$(t menu_new)"*)
                clear
                echo "$(t msg_starting)"
                echo ""
                claude "$@"
                save_session
                ;;
            *"$(t menu_resume)"*)
                if quick_resume; then
                    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF" "$@"
                fi
                ;;
            *"$(t menu_delete)"*)
                delete_session
                ;;
            *"$(t menu_stats)"*)
                show_stats
                ;;
            *"$(t menu_quit)"*)
                clear
                exit 0
                ;;
        esac
    done
}

[[ "${CCSM_TESTING:-}" == "true" ]] || main "$@"
