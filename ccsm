###############################################################################
# Delete session
###############################################################################
delete_session() {
    if $HAS_FZF; then
        [ ! -s "$SESSION_LOG" ] && { echo -e "\n${YELLOW}$(t sessions_none)${RESET}"; return; }

        local selection
        selection=$(tac "$SESSION_LOG" | while IFS=$'\t' read -r sid cwd betreff datum tags; do
            local short_cwd="${cwd/#$HOME/~}"
            echo "${datum}  ${betreff}  ${short_cwd}  ::${sid}::"
        done | fzf --ansi --prompt="$(t fzf_delete_prompt)" --header="$(t fzf_delete_header)" --reverse --height=40%)

        [ -z "$selection" ] && return
        local sid
        sid=$(echo "$selection" | grep -oP '::.*?::' | tr -d ':')
        [ -z "$sid" ] && return

        local betreff
        betreff=$(grep "^${sid}	" "$SESSION_LOG" | cut -f3)
        echo -e "Session: ${CYAN}${betreff}${RESET}"
        echo -n "$(t delete_confirm)"; read -r confirm

        if is_yes "$confirm"; then
            local tmplog="${SESSION_LOG}.tmp"
            grep -v "^${sid}	" "$SESSION_LOG" > "$tmplog"
            mv "$tmplog" "$SESSION_LOG"
            echo -e "${GREEN}$(t delete_done)${RESET}"
        else
            echo "$(t delete_cancelled)"
        fi
    else
        show_sessions || return
        local total
        total=$(wc -l < "$SESSION_LOG")
        echo -n "$(t delete_prompt_nr)"; read -r sel
        [ "$sel" = "q" ] && return
        if ! [[ "$sel" =~ ^[0-9]+$ ]] || [ "$sel" -lt 1 ] || [ "$sel" -gt "$total" ]; then
            echo -e "${YELLOW}$(t err_invalid)${RESET}"
            return
        fi
        local reversed_line=$((total - sel + 1))
        local line
        line=$(sed -n "${reversed_line}p" "$SESSION_LOG")
        local del_betreff
        del_betreff=$(echo "$line" | cut -f3)
        echo -e "Session: ${CYAN}${del_betreff}${RESET}"
        echo -n "$(t delete_confirm)"; read -r confirm
        if is_yes "$confirm"; then
            sed -i "${reversed_line}d" "$SESSION_LOG"
            echo -e "${GREEN}$(t delete_done)${RESET}"
        else
            echo "$(t delete_cancelled)"
        fi
    fi
}

###############################################################################
