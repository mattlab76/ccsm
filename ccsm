# Translation lookup
t() {
    local key="$1"
    if [[ "$CCSM_LANG" == "de" ]]; then
        echo "${L_DE[$key]:-${L_EN[$key]:-$key}}"
    else
        echo "${L_EN[$key]:-$key}"
