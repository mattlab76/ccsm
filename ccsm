#!/bin/bash
# ccsm - Claude Code Session Manager
# https://github.com/mattlab76/ccsm
#
# TUI session manager for Claude Code using gum (fallback: dialog)
# Save, tag, search, and resume Claude Code sessions
#
# Usage:
#   ccsm                  Interactive menu
#   ccsm --search <text>  Search sessions
#   ccsm --stats          Show statistics
#   ccsm --cleanup        Manual cleanup
#   ccsm --help           Show help

CCSM_VERSION="1.4.0"

# Paths
SESSION_LOG="$HOME/.claude/session_log.tsv"
CONFIG_FILE="$HOME/.claude/ccsm.conf"
TMPDIR="/tmp/ccsm"

# Defaults
CLEANUP_DAYS=30
MAX_SESSIONS=0
CCSM_LANG="${CCSM_LANG:-}"

# Load config
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

# Language detection
if [[ -z "${CCSM_LANG:-}" ]]; then
    case "${LC_ALL:-${LANG:-}}" in
        de*) CCSM_LANG="de" ;;
        *)   CCSM_LANG="en" ;;
    esac
fi

