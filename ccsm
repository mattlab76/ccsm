        "$(_hline вФА $_W_TI)" "$(_hline вФА $_W_TO)" "$(_hline вФА $_W_LI)" "$(_hline вФА $_W_LO)"
}

table_bottom() {
    printf 'вФФ%sвФі%sвФі%sвФі%sвФі%sвФі%sвФі%sвФі%sвФШ' \
        "$(_hline вФА $_W_NUM)" "$(_hline вФА $_W_DATE)" "$(_hline вФА $_W_SUBJ)" "$(_hline вФА $_W_DIR)" \
        "$(_hline вФА $_W_TI)" "$(_hline вФА $_W_TO)" "$(_hline вФА $_W_LI)" "$(_hline вФА $_W_LO)"
}

table_header_row() {
    printf 'вФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%*s%bвФВ%b%*s%bвФВ%b%*s%bвФВ%b%*s%bвФВ' \
        "$A_VIOLET" $_W_NUM " #" "$A_RST" \
        "$A_VIOLET" $_W_DATE " Date" "$A_RST" \
        "$A_VIOLET" $_W_SUBJ " Subject" "$A_RST" \
        "$A_VIOLET" $_W_DIR " Directory" "$A_RST" \
