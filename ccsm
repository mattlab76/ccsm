            local query="${browse_input#/}"
            [ -z "$query" ] && { query=$(gum input --placeholder="$(t search_prompt)...") || return 1; }
            _search_and_resume "$query" "${CHOICE_SIDS[@]}"
            return $?
            ;;
        [0-9]*)
            local idx=$((browse_input - 1))
            if [ "$idx" -ge 0 ] && [ "$idx" -lt "$session_count" ]; then
