}

table_data_row() {
    local num="$1" date="$2" subj="$3" dir="$4" ti="$5" to="$6" li="$7" lo="$8"
    printf 'вФВ%-*sвФВ%-*sвФВ%-*sвФВ%-*sвФВ%*sвФВ%*sвФВ%*sвФВ%*sвФВ' \
        $_W_NUM " $num" $_W_DATE " $date" $_W_SUBJ " $subj" $_W_DIR " $dir" \
        $_W_TI "$ti " $_W_TO "$to " $_W_LI "$li " $_W_LO "$lo "
}

# Build complete bordered table as array of lines
# Sets TABLE_SIDS[] for sid lookup by row number
build_table() {
    local max_items="${1:-0}"
    TABLE_SIDS=()
    TABLE_LINES=()
    local idx=0

    if [ ! -s "$SESSION_LOG" ]; then
        return
    fi

    TABLE_LINES+=("$(table_top)")
    TABLE_LINES+=("$(table_header_row)")
    TABLE_LINES+=("$(table_mid)")

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        idx=$((idx + 1))
        TABLE_SIDS+=("$sid")

        local short_cwd="${cwd/#$HOME/\~}"
        local short_betreff="${betreff:0:$((_W_SUBJ - 2))}"
        [ ${#betreff} -gt $((_W_SUBJ - 2)) ] && short_betreff="${short_betreff}.."
        local short_cwd_d="${short_cwd:0:$((_W_DIR - 2))}"
        [ ${#short_cwd} -gt $((_W_DIR - 2)) ] && short_cwd_d="..${short_cwd: -$((_W_DIR - 4))}"

        local tot_in="0" tot_out="0" last_in="0" last_out="0"
        if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
            local total_part="${tokens_col%%|*}"
            local last_part="${tokens_col#*|}"
            [ "$last_part" = "$tokens_col" ] && last_part="$total_part"
            tot_in=$(echo "$total_part" | cut -d/ -f1)
            tot_out=$(echo "$total_part" | cut -d/ -f2)
            last_in=$(echo "$last_part" | cut -d/ -f1)
            last_out=$(echo "$last_part" | cut -d/ -f2)
        fi

        TABLE_LINES+=("$(table_data_row "$idx" "$datum" "$short_betreff" "$short_cwd_d" \
            "$(format_tokens "$tot_in")" "$(format_tokens "$tot_out")" \
            "$(format_tokens "$last_in")" "$(format_tokens "$last_out")")")

        [ "$max_items" -gt 0 ] && [ "$idx" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")

    TABLE_LINES+=("$(table_bottom)")
}

# Build compact table (only Total In/Out, no Last columns) for main menu
