###############################################################################
# Main
###############################################################################
main() {
    case "${1:-}" in
        --search) shift; search_sessions "$*"; return ;;
        --stats) show_stats; return ;;
        --cleanup) check_cleanup; return ;;
        --version|-v) echo "ccsm v${CCSM_VERSION}"; return ;;
        --help|-h) show_help; return ;;
    esac

    check_cleanup

    while true; do
        show_main_menu

        case "$MENU_CHOICE" in
            # Quick resume sessions 1-5
            [1-5])
                local idx=$((MENU_CHOICE - 1))
                if [ "$idx" -lt "${#TABLE_SIDS[@]}" ]; then
                    local sid="${TABLE_SIDS[$idx]}"
                    local line
                    line=$(grep "^${sid}	" "$SESSION_LOG")
                    local r_cwd r_betreff
                    r_cwd=$(echo "$line" | cut -f2)
                    r_betreff=$(echo "$line" | cut -f3)
                    resume_session "$sid" "$r_cwd" "$r_betreff" "$@"
                fi
                ;;
            # Menu actions
            n|N)
                clear
                echo "$(t msg_starting)"
                echo ""
                claude "$@"
                save_session
                ;;
            s|S)
                if quick_resume; then
                    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF" "$@"
                fi
                ;;
            d|D)
                delete_session
                ;;
            i|I)
                show_stats
                ;;
            q|Q|"")
                clear
                exit 0
                ;;
        esac
    done
}

[[ "${CCSM_TESTING:-}" == "true" ]] || main "$@"
