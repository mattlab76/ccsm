###############################################################################
# Resume session
###############################################################################
resume_session() {
    local sid="$1" cwd="$2" betreff="$3"
    shift 3

    echo -e "\n${GREEN}$(t msg_switching): ${cwd}${RESET}"
    echo -e "${GREEN}$(t msg_resuming): ${betreff}${RESET}\n"
    cd "$cwd" || {
        echo -e "${RED}$(t err_no_dir): ${cwd}${RESET}"
        return 1
    }
    claude --resume "$sid" "$@"
    save_session
}

###############################################################################
# Session selection (fzf or classic)
###############################################################################
select_session_fzf() {
    [ ! -s "$SESSION_LOG" ] && { echo -e "\n${YELLOW}$(t sessions_none)${RESET}"; return 1; }

    local selection
    selection=$(tac "$SESSION_LOG" | while IFS=$'\t' read -r sid cwd betreff datum tags; do
        local short_cwd="${cwd/#$HOME/~}"
        local tag_str=""
        [ -n "$tags" ] && [ "$tags" != "-" ] && tag_str=" [$tags]"
        echo "${datum}  ${betreff}${tag_str}  ${short_cwd}  ::${sid}::"
    done | fzf --ansi --prompt="$(t fzf_select_prompt)" --header="$(t fzf_select_header)" --reverse --height=40%)

    [ -z "$selection" ] && return 1

    local sid
