# gum renders its TUI on stderr. Some terminal setups (p10k, zsh plugins)
# suppress stderr display. We redirect stderr to /dev/tty so the TUI is
# always visible, while stdout (the result) stays capturable by $().
gum() { command gum "$@" 2>/dev/tty; }

###############################################################################
# Token formatting: 1353202 -> "1.4M", 47567 -> "47.6k", 102 -> "102"
###############################################################################
format_tokens() {
    local n="$1"
    if [[ -z "$n" ]] || [[ "$n" == "0" ]]; then
        echo "0"
        return
    fi
    # LC_ALL=C ensures dot as decimal separator
    if [ "$n" -ge 1000000 ] 2>/dev/null; then
        LC_ALL=C printf "%.1fM" "$(echo "scale=1; $n/1000000" | LC_ALL=C bc)"
    elif [ "$n" -ge 1000 ] 2>/dev/null; then
        LC_ALL=C printf "%.1fk" "$(echo "scale=1; $n/1000" | LC_ALL=C bc)"
    else
        echo "$n"
    fi
}

###############################################################################
# Helper: days since date
###############################################################################
days_since() {
    local date_str="$1"
    local now today_sec date_sec
    now=$(date '+%Y-%m-%d')
    today_sec=$(date -d "$now" '+%s' 2>/dev/null) || today_sec=$(date '+%s')
    date_sec=$(date -d "$date_str" '+%s' 2>/dev/null) || return 1
    echo $(( (today_sec - date_sec) / 86400 ))
}

###############################################################################
# Build session table rows (array of formatted lines)
# Populates TABLE_SIDS[] for index-based sid lookup
###############################################################################
TABLE_SIDS=()

build_table_rows() {
    local max_items="${1:-0}"
    TABLE_SIDS=()
    local rows=()
    local idx=0

    if [ ! -s "$SESSION_LOG" ]; then
        echo ""
        return
    fi

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        idx=$((idx + 1))
        TABLE_SIDS+=("$sid")

        local short_cwd="${cwd/#$HOME/\~}"
        local short_betreff="${betreff:0:20}"
        [ ${#betreff} -gt 20 ] && short_betreff="${short_betreff}.."
        local short_cwd_d="${short_cwd:0:15}"
        [ ${#short_cwd} -gt 15 ] && short_cwd_d="..${short_cwd: -13}"

        # Parse tokens: format is "total_in/total_out|last_in/last_out" or "total_in/total_out"
        local tot_in="0" tot_out="0" last_in="0" last_out="0"
        if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
            local total_part="${tokens_col%%|*}"
            local last_part="${tokens_col#*|}"
            [ "$last_part" = "$tokens_col" ] && last_part="$total_part"
            tot_in=$(echo "$total_part" | cut -d/ -f1)
            tot_out=$(echo "$total_part" | cut -d/ -f2)
            last_in=$(echo "$last_part" | cut -d/ -f1)
            last_out=$(echo "$last_part" | cut -d/ -f2)
        fi

        local row
        printf -v row "%-3s %-12s %-22s %-17s %8s %8s %8s %8s" \
            "$idx" "$datum" "$short_betreff" "$short_cwd_d" \
            "$(format_tokens "$tot_in")" "$(format_tokens "$tot_out")" \
            "$(format_tokens "$last_in")" "$(format_tokens "$last_out")"
        rows+=("$row")

        [ "$max_items" -gt 0 ] && [ "$idx" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")

    printf '%s\n' "${rows[@]}"
}

###############################################################################
# Format a session table header line
###############################################################################
table_header() {
    printf "%-3s %-12s %-22s %-17s %8s %8s %8s %8s" "#" "Date" "Subject" "Directory" "Tot In" "Tot Out" "Last In" "Last Out"
}

table_separator() {
    printf '%s' "$(printf '%.0s─' {1..100})"
}

###############################################################################
# Render a unified box with gum style
###############################################################################
render_box() {
    local title="$1"
    shift
    # All remaining args are content lines
    gum style \
        --foreground="$C_PRIMARY" \
        --border="rounded" \
        --border-foreground="$C_SECONDARY" \
        --padding="1 2" \
        --margin="0 1" \
        "$title" "$@"
}

###############################################################################
# Cleanup old sessions
###############################################################################
check_cleanup() {
    [ ! -s "$SESSION_LOG" ] && return
    [ "$CLEANUP_DAYS" -eq 0 ] 2>/dev/null && return

    local old_sids=() old_labels=()
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local age
        age=$(days_since "$datum" 2>/dev/null) || continue
        if [ "$age" -ge "$CLEANUP_DAYS" ]; then
            old_sids+=("$sid")
            old_labels+=("${datum} (${age}d) ${betreff}")
        fi
    done < "$SESSION_LOG"

    [ ${#old_sids[@]} -eq 0 ] && return

    local cleanup_title
    printf -v cleanup_title "$(t cleanup_title)" "$CLEANUP_DAYS"

    # Build numbered choices
    local choices=()
    for i in "${!old_labels[@]}"; do
        local num=$((i + 1))
        choices+=("$(printf '%-3s %s' "$num" "${old_labels[$i]}")")
    done

    render_box "$cleanup_title" "" "$(printf '%s\n' "${choices[@]}")"

    local to_delete
    to_delete=$(printf '%s\n' "${choices[@]}" | \
        gum choose --no-limit \
            --header="Space=select Enter=confirm (select sessions to DELETE)" \
        ) || return

    [ -z "$to_delete" ] && return

    # Extract selected indices and map to sids
    local delete_sids=()
    while IFS= read -r selected; do
        local sel_num
        sel_num=$(echo "$selected" | awk '{print $1}')
        local idx=$((sel_num - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#old_sids[@]}" ]; then
            delete_sids+=("${old_sids[$idx]}")
        fi
    done <<< "$to_delete"

    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        local sid_match=false
        for del_sid in "${delete_sids[@]}"; do
            [ "$s" = "$del_sid" ] && sid_match=true && break
        done
        if $sid_match; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        gum style --foreground="$C_ACCENT" "$msg"
        sleep 1
    fi
}

###############################################################################
# Main menu
###############################################################################
show_main_menu() {
    clear

    local logo_line1="  C C S M  v${CCSM_VERSION}"
    local logo_line2="  $(t title)"

    # Build box content
    local box_lines=()
    box_lines+=("$logo_line1")
    box_lines+=("$logo_line2")
    box_lines+=("")

    local count=0
    [ -s "$SESSION_LOG" ] && count=$(wc -l < "$SESSION_LOG")

    if [ -s "$SESSION_LOG" ]; then
        box_lines+=("  Recent sessions ($count total):")
        box_lines+=("")
        box_lines+=("  $(table_header)")
        box_lines+=("  $(table_separator)")

        local table_output
        table_output=$(build_table_rows 5)
        while IFS= read -r row; do
            [ -n "$row" ] && box_lines+=("  $row")
        done <<< "$table_output"
    else
        box_lines+=("  $(t sessions_none)")
    fi

    render_box "" "${box_lines[@]}"
    echo ""

    # Navigation hint below box
    gum style --foreground="$C_DIM" --margin="0 2" \
        "  ↑↓ navigate · Enter select · ESC quit"
    echo ""

    # Menu choices
    local choices=()
    choices+=("$(t menu_new)")
    choices+=("$(t menu_resume)")
    choices+=("$(t menu_delete)")
    choices+=("$(t menu_stats)")
    choices+=("$(t menu_quit)")

    MENU_CHOICE=$(printf '%s\n' "${choices[@]}" | \
        gum choose --height=7) || MENU_CHOICE="$(t menu_quit)"
}

###############################################################################
# Browse / search sessions
###############################################################################
quick_resume() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        sleep 1
        return 1
    fi

    clear

    # Build box with full session table
    local box_lines=()
    box_lines+=("  $(t menu_resume)")
    box_lines+=("")
    box_lines+=("  $(table_header)")
    box_lines+=("  $(table_separator)")

    local table_output
    table_output=$(build_table_rows 0)
    local CHOICE_SIDS=("${TABLE_SIDS[@]}")

    while IFS= read -r row; do
        [ -n "$row" ] && box_lines+=("  $row")
    done <<< "$table_output"

    render_box "" "${box_lines[@]}"
    echo ""
    gum style --foreground="$C_DIM" --margin="0 2" \
        "  ↑↓ navigate · Enter resume · ESC back"
    echo ""

    # Build gum choose items (clean rows, no sid visible)
    local choose_items=()
    local choose_table
    choose_table=$(build_table_rows 0)
    while IFS= read -r row; do
        [ -n "$row" ] && choose_items+=("$row")
    done <<< "$choose_table"

    if [ ${#choose_items[@]} -eq 0 ]; then
        return 1
    fi

    local choice
    choice=$(printf '%s\n' "${choose_items[@]}" | \
        gum choose) || return 1

    # Extract the index number from the choice (first field)
    local sel_num
    sel_num=$(echo "$choice" | awk '{print $1}')
    local idx=$((sel_num - 1))

    if [ "$idx" -lt 0 ] || [ "$idx" -ge "${#CHOICE_SIDS[@]}" ]; then
        return 1
    fi

    local sid="${CHOICE_SIDS[$idx]}"
    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    return 0
}

###############################################################################
# Resume session
###############################################################################
resume_session() {
    local sid="$1" cwd="$2" betreff="$3"
    shift 3

    clear
    gum style --foreground="$C_ACCENT" --bold \
        "$(t msg_switching): $cwd" \
        "$(t msg_resuming): $betreff"
    echo ""

    cd "$cwd" || {
        gum style --foreground="$C_WARN" "$(t err_no_dir): $cwd"
        sleep 2
        return 1
    }
    claude --resume "$sid" "$@"
    save_session
}

###############################################################################
# Delete session
###############################################################################
delete_session() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t sessions_none)"
        sleep 1
        return
    fi

    clear

    # Build table rows once
    local table_output
    table_output=$(build_table_rows 0)
    local DELETE_SIDS=("${TABLE_SIDS[@]}")

    local choose_items=()
    while IFS= read -r row; do
        [ -n "$row" ] && choose_items+=("$row")
    done <<< "$table_output"

    [ ${#choose_items[@]} -eq 0 ] && return

    # Show header + hints, then gum choose
    gum style --foreground="$C_PRIMARY" --bold --margin="0 2" "$(t delete_title)"
    echo ""
    gum style --foreground="$C_DIM" --margin="0 2" "$(table_header)"
    gum style --foreground="$C_DIM" --margin="0 2" "$(table_separator)"
    echo ""

    local choices
    choices=$(printf '%s\n' "${choose_items[@]}" | \
        gum choose --no-limit \
            --header="↑↓ navigate · Space toggle · Enter delete · ESC cancel") || return

    [ -z "$choices" ] && return

    # Collect sids to delete
    local delete_sids=()
    while IFS= read -r selected; do
        local sel_num
        sel_num=$(echo "$selected" | awk '{print $1}')
        local idx=$((sel_num - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#DELETE_SIDS[@]}" ]; then
            delete_sids+=("${DELETE_SIDS[$idx]}")
        fi
    done <<< "$choices"

    [ ${#delete_sids[@]} -eq 0 ] && return

    # Confirm
    gum confirm "$(t delete_confirm) (${#delete_sids[@]} selected)" || return

    # Delete from log
    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        local sid_match=false
        for del_sid in "${delete_sids[@]}"; do
            [ "$s" = "$del_sid" ] && sid_match=true && break
        done
        if $sid_match; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        gum style --foreground="$C_ACCENT" "  ✓ $msg"
        sleep 1
    fi
}

###############################################################################
# Search sessions
###############################################################################
search_sessions() {
    local query="$1"

    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t search_no_sessions)"
        sleep 1
        return 1
    fi

    if [ -z "$query" ]; then
        query=$(gum input \
            --placeholder="$(t search_prompt)..." \
            ) || return 1
        [ -z "$query" ] && return 1
    fi

    local SEARCH_SIDS=()
    local search_rows=()
    local idx=0

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        if echo "$betreff $cwd $tags" | grep -qi "$query"; then
            idx=$((idx + 1))
            SEARCH_SIDS+=("$sid")

            local short_cwd="${cwd/#$HOME/\~}"
            local short_betreff="${betreff:0:20}"
            [ ${#betreff} -gt 20 ] && short_betreff="${short_betreff}.."
            local short_cwd_d="${short_cwd:0:15}"
            [ ${#short_cwd} -gt 15 ] && short_cwd_d="..${short_cwd: -13}"

            local tot_in="0" tot_out="0" last_in="0" last_out="0"
            if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
                local total_part="${tokens_col%%|*}"
                local last_part="${tokens_col#*|}"
                [ "$last_part" = "$tokens_col" ] && last_part="$total_part"
                tot_in=$(echo "$total_part" | cut -d/ -f1)
                tot_out=$(echo "$total_part" | cut -d/ -f2)
                last_in=$(echo "$last_part" | cut -d/ -f1)
                last_out=$(echo "$last_part" | cut -d/ -f2)
            fi

            local row
            printf -v row "%-3s %-12s %-22s %-17s %8s %8s %8s %8s" \
                "$idx" "$datum" "$short_betreff" "$short_cwd_d" \
                "$(format_tokens "$tot_in")" "$(format_tokens "$tot_out")" \
                "$(format_tokens "$last_in")" "$(format_tokens "$last_out")"
            search_rows+=("$row")
        fi
    done < <(tac "$SESSION_LOG")

    if [ ${#search_rows[@]} -eq 0 ]; then
        gum style --foreground="$C_WARN" "$(t search_no_results)"
        sleep 1
        return 1
    fi

    clear

    local box_lines=()
    box_lines+=("  $(t search_title): '$query' (${#search_rows[@]})")
    box_lines+=("")
    box_lines+=("  $(table_header)")
    box_lines+=("  $(table_separator)")
    for row in "${search_rows[@]}"; do
        box_lines+=("  $row")
    done

    render_box "" "${box_lines[@]}"
    echo ""
    gum style --foreground="$C_DIM" --margin="0 2" \
        "  ↑↓ navigate · Enter resume · ESC back"
    echo ""

    local choice
    choice=$(printf '%s\n' "${search_rows[@]}" | \
        gum choose) || return 1

    local sel_num
    sel_num=$(echo "$choice" | awk '{print $1}')
    local sel_idx=$((sel_num - 1))

    if [ "$sel_idx" -lt 0 ] || [ "$sel_idx" -ge "${#SEARCH_SIDS[@]}" ]; then
        return 1
    fi

    local sid="${SEARCH_SIDS[$sel_idx]}"
    local line
    line=$(grep "^${sid}	" "$SESSION_LOG")
    SELECTED_SID=$(echo "$line" | cut -f1)
    SELECTED_CWD=$(echo "$line" | cut -f2)
    SELECTED_BETREFF=$(echo "$line" | cut -f3)
    resume_session "$SELECTED_SID" "$SELECTED_CWD" "$SELECTED_BETREFF"
}

###############################################################################
# Statistics
###############################################################################
show_stats() {
    if [ ! -s "$SESSION_LOG" ]; then
        gum style --foreground="$C_WARN" "$(t stats_none)"
        sleep 1
        return
    fi

    clear
    local total oldest newest
    total=$(wc -l < "$SESSION_LOG")
    oldest=$(head -1 "$SESSION_LOG" | cut -f4)
    newest=$(tail -1 "$SESSION_LOG" | cut -f4)

    # Token totals
    local total_in=0 total_out=0
    while IFS=$'\t' read -r _ _ _ _ _ tk; do
        if [ -n "$tk" ] && [ "$tk" != "0/0" ]; then
            local t_in t_out
            t_in=$(echo "$tk" | cut -d/ -f1)
            t_out=$(echo "$tk" | cut -d/ -f2)
            total_in=$((total_in + t_in))
            total_out=$((total_out + t_out))
        fi
    done < "$SESSION_LOG"

    local fmt_total_in fmt_total_out
    fmt_total_in=$(format_tokens "$total_in")
    fmt_total_out=$(format_tokens "$total_out")

    # Top directories
    local top_dirs
    top_dirs=$(cut -f2 "$SESSION_LOG" | sed "s|$HOME|~|g" | sort | uniq -c | sort -rn | head -5 | \
        awk '{printf "  %dx %s\n", $1, $2}')

    # Top tags
    local top_tags
    top_tags=$(cut -f5 "$SESSION_LOG" 2>/dev/null | grep -v '^$' | grep -v '^-$' | tr ' ' '\n' | sort | uniq -c | sort -rn | head -5)

    # Build session table
    local table_output
    table_output=$(build_table_rows 0)

    # Build box content
    local box_lines=()
    box_lines+=("  $(t stats_title)")
    box_lines+=("")
    box_lines+=("  Version:      ${CCSM_VERSION}")
    box_lines+=("  Sessions:     ${total}")
    box_lines+=("  Oldest:       ${oldest}")
    box_lines+=("  Newest:       ${newest}")
    box_lines+=("  Cleanup:      ${CLEANUP_DAYS} days")
    box_lines+=("  Tokens in:    ${fmt_total_in}")
    box_lines+=("  Tokens out:   ${fmt_total_out}")
    box_lines+=("")
    box_lines+=("  $(table_separator)")
    box_lines+=("")
    box_lines+=("  Top directories:")
    if [ -n "$top_dirs" ]; then
        while IFS= read -r dline; do
            box_lines+=("  $dline")
        done <<< "$top_dirs"
    fi

    if [ -n "$top_tags" ]; then
        box_lines+=("")
        box_lines+=("  $(table_separator)")
        box_lines+=("")
        box_lines+=("  Top tags:")
        while IFS= read -r tline; do
            local formatted
            formatted=$(echo "$tline" | awk '{printf "  %s (%dx)\n", $2, $1}')
            box_lines+=("  $formatted")
        done <<< "$top_tags"
    fi

    box_lines+=("")
    box_lines+=("  $(table_separator)")
    box_lines+=("")
    box_lines+=("  All sessions:")
    box_lines+=("")
    box_lines+=("  $(table_header)")
    box_lines+=("  $(table_separator)")
    while IFS= read -r row; do
        [ -n "$row" ] && box_lines+=("  $row")
    done <<< "$table_output"

    render_box "" "${box_lines[@]}"
    echo ""
    gum style --foreground="$C_DIM" --margin="0 2" \
        "  Enter back"
    echo ""
    gum confirm "OK" --affirmative="Back" --negative="" 2>/dev/null || true
}

###############################################################################
# Subject suggestions from transcript
###############################################################################
generate_suggestions() {
    local transcript="$1" cwd="$2"
    python3 - "$transcript" "$cwd" "$CCSM_LANG" <<'PYEOF'
import json, sys, os

transcript_path = sys.argv[1]
cwd = sys.argv[2]
lang = sys.argv[3] if len(sys.argv) > 3 else "en"
suggestions = []
user_messages = []

try:
    with open(transcript_path) as f:
        for line in f:
            try:
                obj = json.loads(line)
                if obj.get('type') == 'user' and 'message' in obj:
                    msg = obj['message']
                    if isinstance(msg, dict) and msg.get('role') == 'user':
                        for c in msg.get('content', []):
                            if isinstance(c, dict) and c.get('type') == 'text':
                                text = c['text'].strip().replace('\n', ' ').replace('\t', ' ')
                                if len(text) > 5:
                                    user_messages.append(text)
            except (json.JSONDecodeError, KeyError):
                pass
except Exception:
    pass

if user_messages:
    first = user_messages[0][:80]
    if len(user_messages[0]) > 80: first += ".."
    suggestions.append(first)

dir_name = os.path.basename(cwd)
prefix = "Work in" if lang == "en" else "Arbeit in"
if dir_name and dir_name != os.path.basename(os.path.expanduser('~')):
    suggestions.append(f"{prefix}: {dir_name}")

if user_messages and dir_name:
    first_short = user_messages[0][:40]
    if len(user_messages[0]) > 40: first_short += ".."
    suggestions.append(f"{dir_name}: {first_short}")

seen = set()
for s in suggestions:
    if s not in seen:
        seen.add(s)
        print(s)
PYEOF
}

###############################################################################
# Save session (guided gum flow)
###############################################################################
save_session() {
    local tmpfile=""
    tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
    [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ] && [ -f "/tmp/claude-session-end.json" ] && tmpfile="/tmp/claude-session-end.json"

    if [ -z "$tmpfile" ]; then
        local waited=0
        while [ $waited -lt 10 ]; do
            sleep 0.5
            waited=$((waited + 1))
            tmpfile=$(ls -t "$TMPDIR"/session-*.json 2>/dev/null | head -1)
            [ -n "$tmpfile" ] && break
        done
    fi

    if [ -z "$tmpfile" ] || [ ! -f "$tmpfile" ]; then
        gum style --foreground="$C_WARN" "$(t save_no_data)"
        sleep 2
        return
    fi

    local sid cwd betreff transcript tokens
    sid=$(jq -r '.session_id' "$tmpfile" 2>/dev/null)
    cwd=$(jq -r '.cwd' "$tmpfile" 2>/dev/null)
    betreff=$(jq -r '.betreff' "$tmpfile" 2>/dev/null)
    transcript=$(jq -r '.transcript // empty' "$tmpfile" 2>/dev/null)
    tokens=$(jq -r '.tokens // "0/0"' "$tmpfile" 2>/dev/null)
    [ -z "$sid" ] && return

    local datum
    datum=$(date '+%Y-%m-%d')
    local existing_line
    existing_line=$(grep "^${sid}	" "$SESSION_LOG" 2>/dev/null)

    # Parse tokens for display
    local disp_in="0" disp_out="0"
    if [ -n "$tokens" ] && [ "$tokens" != "0/0" ]; then
        disp_in=$(echo "$tokens" | cut -d/ -f1)
        disp_out=$(echo "$tokens" | cut -d/ -f2)
    fi
    local fmt_in fmt_out
    fmt_in=$(format_tokens "$disp_in")
    fmt_out=$(format_tokens "$disp_out")

    echo ""
    local save_lines=()
    save_lines+=("  $(t save_title)")
    save_lines+=("")
    save_lines+=("  Dir:        ${cwd}")
    save_lines+=("  Tokens in:  ${fmt_in}")
    save_lines+=("  Tokens out: ${fmt_out}")
    render_box "" "${save_lines[@]}"
    echo ""

    if [ -n "$existing_line" ]; then
        # Existing session
        local existing_betreff existing_tags existing_tokens
        existing_betreff=$(echo "$existing_line" | cut -f3)
        existing_tags=$(echo "$existing_line" | cut -f5)
        existing_tokens=$(echo "$existing_line" | cut -f6)

        local action
        action=$(printf '%s\n' "$(t save_keep): $existing_betreff" "$(t save_change)" | \
            gum choose) || { rm -f "$tmpfile"; return; }

        local new_betreff="$existing_betreff"
        if [[ "$action" == "$(t save_change)" ]]; then
            new_betreff=$(gum input \
                --value="$existing_betreff" \
                --placeholder="$(t save_enter)") || new_betreff="$existing_betreff"
        fi

        # Accumulate tokens: total_in/total_out|last_in/last_out
        # $tokens = current session's in/out from hook
        local cur_in cur_out
        cur_in=$(echo "$tokens" | cut -d/ -f1)
        cur_out=$(echo "$tokens" | cut -d/ -f2)
        local new_tokens="$tokens|$tokens"
        if [ -n "$existing_tokens" ] && [ "$existing_tokens" != "0/0" ]; then
            local old_total="${existing_tokens%%|*}"
            local old_in old_out
            old_in=$(echo "$old_total" | cut -d/ -f1)
            old_out=$(echo "$old_total" | cut -d/ -f2)
            new_tokens="$(( old_in + cur_in ))/$(( old_out + cur_out ))|${cur_in}/${cur_out}"
        fi

        local tmplog="${SESSION_LOG}.tmp"
        while IFS=$'\t' read -r s c b d t_col tk; do
            if [ "$s" = "$sid" ]; then
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$new_betreff" "$datum" "$t_col" "$new_tokens"
            else
                printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
            fi
        done < "$SESSION_LOG" > "$tmplog"
        mv "$tmplog" "$SESSION_LOG"
        gum style --foreground="$C_ACCENT" "  $(t save_updated): $new_betreff"
    else
        # New session — guided flow

        # Step 1: Save?
        if ! gum confirm "$(t save_want)"; then
            gum style --foreground="$C_DIM" "$(t save_not_saved)"
            rm -f "$tmpfile"
            sleep 1
            return
        fi

        # Step 2: Auto-subject
        local auto_betreff=""
        if [ -n "$transcript" ] && [ -f "$transcript" ]; then
            auto_betreff=$(generate_suggestions "$transcript" "$cwd" | head -1)
        fi
        [ -z "$auto_betreff" ] && auto_betreff="Session $(basename "$cwd") $datum"

        local chosen_betreff=""
        if gum confirm "$(t save_accept)
$auto_betreff"; then
            chosen_betreff="$auto_betreff"
        else
            # Step 3: Custom subject
            while true; do
                chosen_betreff=$(gum input \
                    --value="$auto_betreff" \
                    --placeholder="$(t save_enter)") || { rm -f "$tmpfile"; return; }

                [ -n "$chosen_betreff" ] && break

                if ! gum confirm "$(t save_no_empty)"; then
                    rm -f "$tmpfile"
                    return
                fi
            done
        fi

        # Step 4: Tags
        local chosen_tags="-"
        local tag_input
        tag_input=$(gum input \
            --placeholder="$(t save_tags)" \
            ) || true
        [ -n "$tag_input" ] && chosen_tags=$(echo "$tag_input" | tr '\t' ' ')

        # Save
        chosen_betreff=$(echo "$chosen_betreff" | tr '\t' ' ')
        # Store as total_in/total_out|last_in/last_out (first save: total = last)
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$sid" "$cwd" "$chosen_betreff" "$datum" "$chosen_tags" "${tokens}|${tokens}" >> "$SESSION_LOG"
        gum style --foreground="$C_ACCENT" "  $(t save_saved): $chosen_betreff"
    fi

    sleep 1
    rm -f "$tmpfile"
}

###############################################################################
# Help
###############################################################################
show_help() {
    if [[ "$CCSM_LANG" == "de" ]]; then
        cat <<EOF
ccsm v${CCSM_VERSION} — Claude Code Session Manager

Nutzung:
  ccsm                  Interaktives Menü
  ccsm --search <text>  Sessions durchsuchen
  ccsm --stats          Statistiken anzeigen
  ccsm --cleanup        Cleanup manuell starten
  ccsm --version        Version anzeigen
  ccsm --help           Diese Hilfe

Konfiguration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30       Tage bis Session als alt gilt
  MAX_SESSIONS=0        Max. Sessions (0=unbegrenzt)
  CCSM_LANG=de          Sprache (en, de)
EOF
    else
        cat <<EOF
ccsm v${CCSM_VERSION} — Claude Code Session Manager

Usage:
  ccsm                  Interactive menu
  ccsm --search <text>  Search sessions
  ccsm --stats          Show statistics
  ccsm --cleanup        Manual cleanup
  ccsm --version        Show version
  ccsm --help           Show this help

Configuration: ~/.claude/ccsm.conf
  CLEANUP_DAYS=30       Days until session is considered old
  MAX_SESSIONS=0        Max sessions (0=unlimited)
