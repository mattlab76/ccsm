###############################################################################
# Display helpers
###############################################################################
setup_display() {
    COLS=$(tput cols 2>/dev/null || echo 80)
    WIDTH=$((COLS < 60 ? 60 : COLS))
    INNER=$((WIDTH - 2))
    HLINE=""
    for ((i=0; i<INNER; i++)); do HLINE+="ŌöĆ"; done
    EMPTY_LINE=$(printf "Ōöé%-${INNER}sŌöé" "")
}

center_text() {
    local text="$1" text_len=${#1}
    local pad_left=$(( (INNER - text_len) / 2 ))
    local pad_right=$(( INNER - text_len - pad_left ))
    printf "Ōöé%${pad_left}s%s%${pad_right}sŌöé" "" "$text" ""
}

center_ansi() {
    local text="$1"
    local visible
    visible=$(echo -e "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local visible_len=${#visible}
    local pad_left=$(( (INNER - visible_len) / 2 ))
    local pad_right=$(( INNER - visible_len - pad_left ))
    printf "Ōöé%${pad_left}s%b%${pad_right}sŌöé" "" "$text" ""
}

menu_item() {
    local text="$1"
    local visible
    visible=$(echo -e "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local visible_len=${#visible}
    local pad=$((INNER - visible_len - 6))
    printf "Ōöé      %b%${pad}sŌöé" "$text" ""
}

###############################################################################
# days_since
###############################################################################
days_since() {
    local date_str="$1"
    local now today_sec date_sec
    now=$(date '+%Y-%m-%d')
    today_sec=$(date -d "$now" '+%s' 2>/dev/null) || today_sec=$(date '+%s')
    date_sec=$(date -d "$date_str" '+%s' 2>/dev/null) || return 1
    echo $(( (today_sec - date_sec) / 86400 ))
}

###############################################################################
# Cleanup
###############################################################################
check_cleanup() {
    [ ! -s "$SESSION_LOG" ] && return
    [ "$CLEANUP_DAYS" -eq 0 ] 2>/dev/null && return

    local old_sessions=()
    while IFS=$'\t' read -r sid cwd betreff datum tags; do
        local age
        age=$(days_since "$datum" 2>/dev/null) || continue
        if [ "$age" -ge "$CLEANUP_DAYS" ]; then
            old_sessions+=("$datum|$betreff|$cwd|$sid")
        fi
    done < "$SESSION_LOG"

    [ ${#old_sessions[@]} -eq 0 ] && return

    echo ""
    printf "${YELLOW}${BOLD}ŌĢÉŌĢÉŌĢÉ $(t cleanup_title) ŌĢÉŌĢÉŌĢÉ${RESET}\n" "$CLEANUP_DAYS"
    echo ""

    local to_delete=()
    for entry in "${old_sessions[@]}"; do
        IFS='|' read -r datum betreff cwd sid <<< "$entry"
        local short_cwd="${cwd/#$HOME/~}"
        local age
        age=$(days_since "$datum")

        echo -e "  ${DIM}${datum} (${age} $(t cleanup_days | sed "s/%d/$age/"))${RESET}  ${BOLD}${betreff}${RESET}"
        echo -e "  ${CYAN}${short_cwd}${RESET}"
        echo -n "  $(t cleanup_prompt)"; read -r action

        if [ "$action" = "d" ] || [ "$action" = "D" ]; then
            to_delete+=("$sid")
        fi
        echo ""
    done

    if [ ${#to_delete[@]} -gt 0 ]; then
        local tmplog="${SESSION_LOG}.tmp"
        while IFS=$'\t' read -r s c b d t_col; do
            local skip=false
            for del_sid in "${to_delete[@]}"; do
                [ "$s" = "$del_sid" ] && skip=true && break
            done
            $skip || printf '%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col"
        done < "$SESSION_LOG" > "$tmplog"
        mv "$tmplog" "$SESSION_LOG"
        printf "${GREEN}$(t cleanup_deleted)${RESET}\n" "${#to_delete[@]}"
    fi
}

