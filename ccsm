    local max_items="${1:-0}"
    TABLE_SIDS=()
    local idx=0
    local lines=()

    if [ ! -s "$SESSION_LOG" ]; then
        return
    fi

    # Compact column widths: wider subject/dir since no Last columns
    local cw_num=3 cw_date=12
    local cols
    cols=$(tput cols 2>/dev/null || echo 100)
    local avail=$((cols - 16))
    local cw_ti=$((avail * 9 / 100)); [ "$cw_ti" -lt 10 ] && cw_ti=10
    local cw_to=$cw_ti
    local remaining=$((avail - cw_num - cw_date - cw_ti - cw_to - 7))
    local cw_subj=$((remaining * 55 / 100)); [ "$cw_subj" -lt 20 ] && cw_subj=20
    local cw_dir=$((remaining - cw_subj)); [ "$cw_dir" -lt 16 ] && cw_dir=16

    # Horizontal line helper
    _hl() { local s=""; for ((i=0; i<$1; i++)); do s+="вФА"; done; echo -n "$s"; }

    lines+=("$(printf 'вФМ%sвФђ%sвФђ%sвФђ%sвФђ%sвФђ%sвФР' "$(_hl $cw_num)" "$(_hl $cw_date)" "$(_hl $cw_subj)" "$(_hl $cw_dir)" "$(_hl $cw_ti)" "$(_hl $cw_to)")")
    lines+=("$(printf 'вФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%-*s%bвФВ%b%*s%bвФВ%b%*s%bвФВ' \
        "$A_VIOLET" $cw_num " #" "$A_RST" \
        "$A_VIOLET" $cw_date " Date" "$A_RST" \
        "$A_VIOLET" $cw_subj " Subject" "$A_RST" \
        "$A_VIOLET" $cw_dir " Directory" "$A_RST" \
        "$A_VIOLET" $cw_ti "Total In " "$A_RST" \
        "$A_VIOLET" $cw_to "Total Out" "$A_RST")")
    lines+=("$(printf 'вФЬ%sвФЉ%sвФЉ%sвФЉ%sвФЉ%sвФЉ%sвФ§' "$(_hl $cw_num)" "$(_hl $cw_date)" "$(_hl $cw_subj)" "$(_hl $cw_dir)" "$(_hl $cw_ti)" "$(_hl $cw_to)")")

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        idx=$((idx + 1))
        TABLE_SIDS+=("$sid")

        local short_betreff="${betreff:0:$((cw_subj - 2))}"
        [ ${#betreff} -gt $((cw_subj - 2)) ] && short_betreff="${short_betreff}.."
        local short_cwd="${cwd/#$HOME/\~}"
        local short_cwd_d="${short_cwd:0:$((cw_dir - 2))}"
        [ ${#short_cwd} -gt $((cw_dir - 2)) ] && short_cwd_d="..${short_cwd: -$((cw_dir - 4))}"

        local tot_in="0" tot_out="0"
        if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
            local total_part="${tokens_col%%|*}"
            tot_in=$(echo "$total_part" | cut -d/ -f1)
            tot_out=$(echo "$total_part" | cut -d/ -f2)
        fi

        lines+=("$(printf 'вФВ%-*sвФВ%-*sвФВ%-*sвФВ%-*sвФВ%*sвФВ%*sвФВ' \
            $cw_num " $idx" $cw_date " $datum" $cw_subj " $short_betreff" $cw_dir " $short_cwd_d" \
            $cw_ti "$(format_tokens "$tot_in") " $cw_to "$(format_tokens "$tot_out") ")")

        [ "$max_items" -gt 0 ] && [ "$idx" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")

    lines+=("$(printf 'вФФ%sвФі%sвФі%sвФі%sвФі%sвФі%sвФШ' "$(_hl $cw_num)" "$(_hl $cw_date)" "$(_hl $cw_subj)" "$(_hl $cw_dir)" "$(_hl $cw_ti)" "$(_hl $cw_to)")")

    COMPACT_TABLE_LINES=("${lines[@]}")
}

# Build plain rows for gum choose (no borders, just numbered rows for selection)
build_choice_rows() {
    local max_items="${1:-0}"
    TABLE_SIDS=()
    local idx=0

    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        idx=$((idx + 1))
        TABLE_SIDS+=("$sid")

        local short_betreff="${betreff:0:20}"
        [ ${#betreff} -gt 20 ] && short_betreff="${short_betreff}.."
        local short_cwd="${cwd/#$HOME/\~}"
        local short_cwd_d="${short_cwd:0:16}"
        [ ${#short_cwd} -gt 16 ] && short_cwd_d="..${short_cwd: -14}"

        local tot_in="0" tot_out="0"
        if [ -n "$tokens_col" ] && [ "$tokens_col" != "0/0" ]; then
            local total_part="${tokens_col%%|*}"
            tot_in=$(echo "$total_part" | cut -d/ -f1)
            tot_out=$(echo "$total_part" | cut -d/ -f2)
        fi

        printf "%-3s %-12s %-20s %-16s %7s %7s\n" \
            "$idx" "$datum" "$short_betreff" "$short_cwd_d" \
            "$(format_tokens "$tot_in")" "$(format_tokens "$tot_out")"

        [ "$max_items" -gt 0 ] && [ "$idx" -ge "$max_items" ] && break
    done < <(tac "$SESSION_LOG")
}

###############################################################################
# Render a unified box with gum style
###############################################################################
render_box() {
    local title="$1"
    shift
    # Manual box drawing with echo -e to support ANSI colors in content
    local cols
    cols=$(tput cols 2>/dev/null || echo 100)
    local inner=$((cols - 4))
    [ "$inner" -lt 60 ] && inner=60

    # Build horizontal line
    local hline=""
    for ((i=0; i<inner; i++)); do hline+="вФА"; done

    # Helper: print a line with correct right-border alignment
    _boxline() {
        local content="$1"
        # Get visible length (strip ANSI codes)
        local visible
        visible=$(echo -e "$content" | sed 's/\x1b\[[0-9;]*m//g')
        local vlen=${#visible}
        local pad=$((inner - vlen))
        [ "$pad" -lt 0 ] && pad=0
        local spaces=""
        for ((i=0; i<pad; i++)); do spaces+=" "; done
        echo -e "  \033[38;5;36mвФВ\033[0m${content}${spaces}\033[38;5;36mвФВ\033[0m"
    }

    # Top border
    echo -e "  \033[38;5;36mвХ≠${hline}вХЃ\033[0m"

    # Empty line
    _boxline ""

    # Content lines
    for line in "$@"; do
        _boxline " $line"
    done

    # Empty line
    _boxline ""

    # Bottom border
    echo -e "  \033[38;5;36mвХ∞${hline}вХѓ\033[0m"
}

###############################################################################
# Cleanup old sessions
###############################################################################
check_cleanup() {
    [ ! -s "$SESSION_LOG" ] && return
    [ "$CLEANUP_DAYS" -eq 0 ] 2>/dev/null && return

    local old_sids=() old_labels=()
    while IFS=$'\t' read -r sid cwd betreff datum tags tokens_col; do
        local age
        age=$(days_since "$datum" 2>/dev/null) || continue
        if [ "$age" -ge "$CLEANUP_DAYS" ]; then
            old_sids+=("$sid")
            old_labels+=("${datum} (${age}d) ${betreff}")
        fi
    done < "$SESSION_LOG"

    [ ${#old_sids[@]} -eq 0 ] && return

    local cleanup_title
    printf -v cleanup_title "$(t cleanup_title)" "$CLEANUP_DAYS"

    # Build numbered choices
    local choices=()
    for i in "${!old_labels[@]}"; do
        local num=$((i + 1))
        choices+=("$(printf '%-3s %s' "$num" "${old_labels[$i]}")")
    done

    render_box "$cleanup_title" "" "$(printf '%s\n' "${choices[@]}")"

    local to_delete
    to_delete=$(printf '%s\n' "${choices[@]}" | \
        gum choose --no-limit \
            --header="Space=select Enter=confirm (select sessions to DELETE)" \
        ) || return

    [ -z "$to_delete" ] && return

    # Extract selected indices and map to sids
    local delete_sids=()
    while IFS= read -r selected; do
        local sel_num
        sel_num=$(echo "$selected" | awk '{print $1}')
        local idx=$((sel_num - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#old_sids[@]}" ]; then
            delete_sids+=("${old_sids[$idx]}")
        fi
    done <<< "$to_delete"

    local tmplog="${SESSION_LOG}.tmp"
    local del_count=0
    while IFS=$'\t' read -r s c b d t_col tk; do
        local sid_match=false
        for del_sid in "${delete_sids[@]}"; do
            [ "$s" = "$del_sid" ] && sid_match=true && break
        done
        if $sid_match; then
            del_count=$((del_count + 1))
        else
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$s" "$c" "$b" "$d" "$t_col" "$tk"
        fi
    done < "$SESSION_LOG" > "$tmplog"
    mv "$tmplog" "$SESSION_LOG"

    if [ "$del_count" -gt 0 ]; then
        local msg
        printf -v msg "$(t cleanup_done)" "$del_count"
        gum style --foreground="$C_ACCENT" "$msg"
        sleep 1
    fi
}

