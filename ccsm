    box_lines+=("  Oldest:        ${oldest}")
    box_lines+=("  Newest:        ${newest}")
    box_lines+=("  Cleanup:       ${CLEANUP_DAYS} days")
    box_lines+=("  Tokens in:     ${A_BOLD}${fmt_total_in}${A_RST}")
    box_lines+=("  Tokens out:    ${A_BOLD}${fmt_total_out}${A_RST}")
    box_lines+=("")
    box_lines+=("$dline")
    box_lines+=("  ${A_TEAL}${A_BOLD}Top Directories${A_RST}")
    box_lines+=("")
    if [ -n "$top_dirs" ]; then
        while IFS= read -r dline_item; do
            local cnt dir
            cnt=$(echo "$dline_item" | awk '{print $1}')
            dir=$(echo "$dline_item" | awk '{print $2}')
            box_lines+=("  ${A_GREEN}${cnt}x${A_RST}  ${dir}")
        done <<< "$top_dirs"
    fi

    if [ -n "$top_tags" ]; then
        box_lines+=("")
        box_lines+=("$dline")
        box_lines+=("  ${A_TEAL}${A_BOLD}Top Tags${A_RST}")
