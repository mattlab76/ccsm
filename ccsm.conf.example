# ccsm - Claude Code Session Manager
# Configuration file / Konfigurationsdatei
# Save to / Speichern unter: ~/.claude/ccsm.conf

# Language / Sprache (en, de) — auto-detected from system locale if not set
# CCSM_LANG=en

# Days after which a session is considered "old" (0 = disabled)
# Tage nach denen eine Session als "alt" gilt (0 = deaktiviert)
CLEANUP_DAYS=30
